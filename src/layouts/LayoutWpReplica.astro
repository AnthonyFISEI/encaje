---
import SEO from "../components/SEO.astro";

let {
	title = "Encaje - Soluciones Constructivas",
	description = "Proyectamos y construimos con rigurosa planificación y el mejor equipo técnico.",
	image = "logo.svg",
	errorMsg = null,
} = Astro.props;
const base =
	import.meta.env.BASE_URL === "/" ? "/" : `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<SEO title={title} description={description} image={image} />

		<!-- Google Fonts: Montserrat -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<!-- Font Awesome for original social icons -->
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css"
			integrity="sha512-1ycn6IcaQQ40/MKBW2W4Rhis/DbILU74C1vSrLJxCq57o941Ym01SwNsOMqvEBFlcgUa6xLiPY/NS5R+E6ztJQ=="
			crossorigin="anonymous"
			referrerpolicy="no-referrer"
		/>

		<!-- Material Icons for differentiating sections -->
		<link
			href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- WP Preloader -->
		<div id="ip-container" class="ip-container loading">
			<div class="ip-header">
				<p class="ip-logo">
					<img src={`${base}logo.png`} alt="ENCAJE" />
				</p>
				<div class="ip-loader">
					<svg
						class="ip-inner"
						width="100px"
						height="100px"
						viewBox="0 0 80 80"
					>
						<path
							class="ip-loader-circlebg"
							d="M40,10C57.351,10,71,23.649,71,40.5S57.351,71,40.5,71 S10,57.351,10,40.5S23.649,10,40.5,10z"
						></path>
						<path
							id="ip-loader-circle"
							class="ip-loader-circle"
							d="M40,10C57.351,10,71,23.649,71,40.5S57.351,71,40.5,71 S10,57.351,10,40.5S23.649,10,40.5,10z"
						></path>
					</svg>
				</div>
			</div>
		</div>

		<!-- Left Sidebar Line -->
		<header class="wp-header">
			<!-- Top contact info -->
			<div class="wp-top-contact-info">
				<span><i class="fas fa-phone-alt"></i> +593 98 311 6325</span>
				<span class="wp-separator">|</span>
				<span><i class="far fa-envelope"></i> info@encaje.ec</span>
			</div>

			<!-- Logo Box -->
			<div class="wp-logo-box">
				<a href={`${base}replica-wp`}>
					<img
						src={`${base}logo.png`}
						alt="ENCAJE"
						class="wp-logo-img"
					/>
				</a>
			</div>

			<!-- Menu toggle button -->
			<button
				id="wp-menu-toggle"
				class="wp-open-menu-toggle"
				aria-label="Toggle Menu"
			>
				<span></span>
				<span></span>
				<span></span>
			</button>

			<!-- Sidebar vertical bar -->
			<div class="wp-sidebar-line">
				<!-- Social icons list -->
				<div class="wp-social-line">
					<ul class="wp-social-list">
						<li>
							<a
								href="https://www.facebook.com/ENCAJEC"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Facebook"
								><i class="fab fa-facebook-f"></i></a
							>
						</li>
						<li>
							<a
								href="https://www.instagram.com/encaje.ec"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Instagram"
								><i class="fab fa-instagram"></i></a
							>
						</li>
						<li>
							<a
								href="https://www.tiktok.com/@encaje.ec"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="TikTok"
								><i class="fab fa-tiktok"></i></a
							>
						</li>
						<li>
							<a
								href="https://www.linkedin.com/company/encaje-ec/"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="LinkedIn"
								><i class="fab fa-linkedin-in"></i></a
							>
						</li>
						<li>
							<a
								href="https://www.youtube.com/@encaje-ec"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="YouTube"
								><i class="fab fa-youtube"></i></a
							>
						</li>
					</ul>
				</div>

				<!-- Vertical Copyright -->
				<div class="wp-copyright-line">
					<p>© 2026 Encaje</p>
				</div>
			</div>

			<!-- Navigation panel (slides out) -->
			<nav id="wp-nav-panel" class="wp-nav-menu-box">
				<ul class="wp-navigation-menu-list">
					<li>
						<a href={`${base}replica-wp`}>
							<span class="menu-line-fill"></span>
							<span class="menu-text">Inicio</span>
							<span class="menu-arrow-box"
								><i class="fas fa-chevron-down"></i></span
							>
						</a>
					</li>
					<li>
						<a href={`${base}replica-wp/proyectos`}>
							<span class="menu-line-fill"></span>
							<span class="menu-text">Proyectos</span>
							<span class="menu-arrow-box"
								><i class="fas fa-chevron-down"></i></span
							>
						</a>
					</li>
					<li>
						<a href={`${base}replica-wp/blog`}>
							<span class="menu-line-fill"></span>
							<span class="menu-text">Blog</span>
							<span class="menu-arrow-box"
								><i class="fas fa-chevron-down"></i></span
							>
						</a>
					</li>
					<li>
						<a href={`${base}replica-wp/quienes-somos`}>
							<span class="menu-line-fill"></span>
							<span class="menu-text">Quienes Somos</span>
							<span class="menu-arrow-box"
								><i class="fas fa-chevron-down"></i></span
							>
						</a>
					</li>
					<li>
						<a href={`${base}replica-wp/contacto`}>
							<span class="menu-line-fill"></span>
							<span class="menu-text">Contacto</span>
							<span class="menu-arrow-box"
								><i class="fas fa-chevron-down"></i></span
							>
						</a>
					</li>
				</ul>
			</nav>
		</header>

		<!-- Main Content Area -->
		<div id="wp-content-wrapper" class="wp-content-container">
			{
				errorMsg && (
					<div class="wp-connection-error-banner">
						<div class="wp-error-banner-content">
							<i class="fas fa-exclamation-triangle" />
							<span>
								<strong>
									ALERTA DE CONEXIÓN CON WORDPRESS:
								</strong>{" "}
								{errorMsg}
							</span>
						</div>
					</div>
				)
			}
			<slot />

			<!-- Footer Section -->
			<footer class="wp-footer-section">
				<div class="wp-footer-container">
					<!-- Col 1: Logo -->
					<div class="wp-footer-col">
						<img
							src={`${base}logo.png`}
							alt="ENCAJE"
							class="wp-footer-logo"
						/>
					</div>

					<!-- Col 2: Ubicaciones -->
					<div class="wp-footer-col">
						<h4>NOSOTROS</h4>
						<p class="wp-footer-desc">
							Proyectamos y construimos desde la responsabilidad
							social de la arquitectura y la ingeniería con el
							entorno y la sociedad.
						</p>
					</div>

					<!-- Col 3: Síguenos -->
					<div class="wp-footer-col">
						<h4>SÍGUENOS</h4>
						<div class="wp-footer-socials">
							<a
								href="https://www.facebook.com/ENCAJEC"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Facebook"
								><i class="fab fa-facebook-f"></i></a
							>
							<a
								href="https://www.instagram.com/encaje.ec"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="Instagram"
								><i class="fab fa-instagram"></i></a
							>
							<a
								href="https://www.tiktok.com/@encaje.ec"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="TikTok"
								><i class="fab fa-tiktok"></i></a
							>
							<a
								href="https://www.linkedin.com/company/encaje-ec/"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="LinkedIn"
								><i class="fab fa-linkedin-in"></i></a
							>
							<a
								href="https://www.youtube.com/@encaje-ec"
								target="_blank"
								rel="noopener noreferrer"
								aria-label="YouTube"
								><i class="fab fa-youtube"></i></a
							>
						</div>
					</div>

					<!-- Col 4: Contáctanos -->
					<div class="wp-footer-col">
						<h4>CONTÁCTANOS</h4>
						<p class="wp-footer-contact">
							+593 98 311 6325<br />
							info@encaje.ec
						</p>
					</div>
				</div>
			</footer>
		</div>

		<!-- Script to toggle the sidebar menu -->
		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				const toggleBtn = document.getElementById("wp-menu-toggle");
				const navPanel = document.getElementById("wp-nav-panel");
				const logoBox = document.querySelector(".wp-logo-box");

				if (toggleBtn && navPanel) {
					toggleBtn.addEventListener("click", (e) => {
						e.preventDefault();
						toggleBtn.classList.toggle("active");
						navPanel.classList.toggle("active");
						if (logoBox) {
							logoBox.classList.toggle("active");
						}
					});
				}
			});
		</script>

		<!-- Preloader script -->
		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				const container = document.getElementById("ip-container");
				const circle = document.getElementById("ip-loader-circle");

				if (container && circle) {
					const length = 192; // Circumference of circle
					circle.style.strokeDasharray = `${length} ${length}`;
					circle.style.strokeDashoffset = length;

					let progress = 0;

					// Disable scroll initially
					document.body.style.overflow = "hidden";

					const interval = setInterval(() => {
						progress = Math.min(progress + Math.random() * 0.1, 1);
						circle.style.strokeDashoffset = length * (1 - progress);

						if (progress === 1) {
							clearInterval(interval);

							// Switch classes to animate out
							container.classList.remove("loading");
							container.classList.add("loaded");

							// Re-enable scroll after animations complete
							setTimeout(() => {
								document.body.style.overflow = "";
							}, 1000);
						}
					}, 80);
				}
			});
		</script>

		<!-- Floating WhatsApp Button -->
		<a
			href="https://api.whatsapp.com/send?phone=593983116325&text=Saludos%20Encaje%2C%20estoy%20visitando%20su%20web%20y%20requiero%20informaci%C3%B3n%20de%20sus%20servicios.%20"
			class="wp-whatsapp-float"
			target="_blank"
			rel="noopener noreferrer"
			aria-label="Contactar por WhatsApp"
		>
			<span class="wp-whatsapp-tooltip">Contáctanos</span>
			<div class="wp-whatsapp-ripple"></div>
			<!-- FontAwesome is loaded in LayoutWpReplica.astro, so we can use its standard icon -->
			<i class="fab fa-whatsapp"></i>
		</a>
	</body>
</html>

<style is:global>
	:root {
		--wp-bg-dark: #242424;
		--wp-bg-darker: #272727;
		--wp-bg-panel: #717171;
		--wp-bg-sidebar: #3d3d3d;
		--wp-accent-yellow: #d6a33b;
		--wp-accent-gold: #d6a33b;
		--wp-text-light: #ffffff;
		--wp-text-muted: rgba(255, 255, 255, 0.8);
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		background: var(--wp-bg-dark);
		font-family: "Montserrat", sans-serif;
		color: var(--wp-text-light);
		min-height: 100vh;
		overflow-x: hidden;
	}

	/* Top Contact Info */
	.wp-top-contact-info {
		position: fixed;
		top: 38px;
		right: 40px;
		z-index: 997;
		display: flex;
		align-items: center;
		gap: 15px;
		font-size: 13px;
		color: rgba(255, 255, 255, 0.7);
		font-weight: 400;
	}

	.wp-top-contact-info i {
		color: var(--wp-accent-gold);
		margin-right: 5px;
	}

	.wp-separator {
		color: rgba(255, 255, 255, 0.2);
	}

	/* WP Logo Box */
	.wp-logo-box {
		position: fixed;
		top: 0;
		left: 100px;
		width: 300px;
		height: 100px;
		padding: 20px 30px;
		background-color: var(--wp-bg-darker);
		z-index: 1010;
		transition:
			left 0.4s cubic-bezier(0.77, 0, 0.175, 1) 0.3s,
			width 0.4s cubic-bezier(0.77, 0, 0.175, 1) 0.3s;
		display: flex;
		align-items: center;
		justify-content: flex-start;
	}

	.wp-logo-box.active {
		left: 0;
		width: 400px;
		transition:
			left 0.4s cubic-bezier(0.77, 0, 0.175, 1) 0s,
			width 0.4s cubic-bezier(0.77, 0, 0.175, 1) 0s;
	}

	.wp-logo-img {
		max-width: 100%;
		max-height: 80px;
		height: auto;
		width: auto;
		display: block;
	}

	/* WP Sidebar Line */
	.wp-sidebar-line {
		position: fixed;
		top: 0;
		left: 0;
		bottom: 0;
		width: 100px;
		background: var(--wp-bg-sidebar);
		z-index: 1000;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		align-items: center;
	}

	/* Hamburger menu toggle button */
	.wp-open-menu-toggle {
		position: fixed;
		top: 0;
		left: 0;
		display: flex;
		justify-content: center;
		align-items: center;
		width: 100px;
		height: 100px;
		background-color: var(--wp-accent-yellow);
		border: none;
		cursor: pointer;
		outline: none;
		z-index: 1020;
		transition: top 0.4s cubic-bezier(0.77, 0, 0.175, 1) 0.3s;
	}

	.wp-open-menu-toggle span {
		position: absolute;
		display: block;
		width: 28px;
		height: 2px;
		background-color: var(--wp-text-light);
		transition:
			transform 0.3s ease-in-out,
			opacity 0.3s ease-in-out,
			width 0.3s ease-in-out;
	}

	.wp-open-menu-toggle span:nth-child(1) {
		transform: translateY(-8px);
	}

	.wp-open-menu-toggle span:nth-child(2) {
		transform: translateY(0);
	}

	.wp-open-menu-toggle span:nth-child(3) {
		transform: translateY(8px);
		width: 18px;
	}

	/* Hamburger Menu Active state animations */
	.wp-open-menu-toggle.active {
		top: 100px;
		transition: top 0.4s cubic-bezier(0.77, 0, 0.175, 1) 0s;
	}

	.wp-open-menu-toggle.active span {
		width: 28px;
	}

	.wp-open-menu-toggle.active span:nth-child(1) {
		transform: translateY(0) rotate(45deg);
	}

	.wp-open-menu-toggle.active span:nth-child(2) {
		opacity: 0;
		transform: scale(0);
	}

	.wp-open-menu-toggle.active span:nth-child(3) {
		transform: translateY(0) rotate(-45deg);
	}

	/* Social Media Line in Sidebar */
	.wp-social-line {
		padding: 20px 0;
		text-align: center;
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		margin-bottom: 2rem;
		position: relative;
	}

	.wp-social-line::before {
		content: "";
		position: absolute;
		top: 30px;
		left: 50%;
		bottom: 30px;
		width: 1px;
		background-color: #4c4c4c;
		z-index: 1;
	}

	.wp-social-list {
		list-style: none;
		position: relative;
		z-index: 2;
	}

	.wp-social-list li {
		margin-bottom: 13px;
	}

	.wp-social-list li a {
		display: inline-flex;
		justify-content: center;
		align-items: center;
		width: 40px;
		height: 40px;
		border: 1px solid #4c4c4c;
		border-radius: 50%;
		color: rgba(255, 255, 255, 0.4);
		text-decoration: none;
		background-color: var(--wp-bg-sidebar);
		transition: all 0.2s ease-in-out;
	}

	.wp-social-list li a:hover {
		background-color: var(--wp-accent-yellow);
		color: var(--wp-text-light);
		border-color: transparent;
	}

	/* Vertical Copyright in Sidebar */
	.wp-copyright-line {
		text-align: center;
		height: 250px;
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--wp-bg-darker);
	}

	.wp-copyright-line p {
		color: var(--wp-text-light);
		font-size: 14px;
		writing-mode: vertical-rl;
		transform: rotate(180deg);
		margin: 0;
		font-weight: 500;
		letter-spacing: 0.05em;
	}

	/* Navigation Panel (Slides Out) */
	.wp-nav-menu-box {
		position: fixed;
		top: 100px;
		left: 100px;
		width: 300px;
		height: calc(100vh - 100px);
		background-color: #5b5b5b;
		padding: 20px 20px 40px;
		opacity: 0;
		pointer-events: none;
		transform: translateY(-30px);
		transition:
			transform 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0s,
			opacity 0.4s ease 0s;
		z-index: 995;
		overflow-y: auto;
		display: flex !important;
		flex-direction: column !important;
		align-items: center !important;
		justify-content: flex-start !important;
	}

	.wp-nav-menu-box.active {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0);
		transition:
			transform 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.3s,
			opacity 0.5s ease 0.3s;
	}

	.wp-navigation-menu-list {
		position: relative;
		list-style: none;
		padding: 10px 0;
		margin: 0 auto !important;
		width: 100%;
		max-width: 260px;
		counter-reset: menu-counter;
	}

	/* Left vertical grid line */
	.wp-navigation-menu-list::before {
		content: "";
		position: absolute;
		top: 0;
		bottom: 0;
		left: 50px;
		width: 1px;
		background-color: rgba(255, 255, 255, 0.06);
		z-index: 1;
	}

	/* Right vertical grid line */
	.wp-navigation-menu-list::after {
		content: "";
		position: absolute;
		top: 0;
		bottom: 0;
		right: 35px;
		width: 1px;
		background-color: rgba(255, 255, 255, 0.06);
		z-index: 1;
	}

	.wp-navigation-menu-list > li {
		position: relative;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
		height: 90px;
		display: flex;
		align-items: center;
		counter-increment: menu-counter;
	}

	.wp-navigation-menu-list > li:first-child {
		border-top: 1px solid rgba(255, 255, 255, 0.06);
	}

	/* Leftmost static horizontal grid line segment */
	.wp-navigation-menu-list > li::after {
		content: "";
		position: absolute;
		left: 0;
		width: 50px;
		height: 1px;
		background-color: rgba(255, 255, 255, 0.06);
		top: 50%;
		transform: translateY(-50%);
		z-index: 1;
	}

	/* Number prefix style */
	.wp-navigation-menu-list > li::before {
		content: "0" counter(menu-counter);
		position: absolute;
		left: 10px;
		font-size: 16px;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.15);
		font-family: "Montserrat", sans-serif;
		background-color: #5b5b5b;
		padding: 0 6px;
		z-index: 2;
		transition: all 0.3s ease;
	}

	.wp-navigation-menu-list > li:hover::before {
		color: var(--wp-accent-yellow);
	}

	/* Link container */
	.wp-navigation-menu-list > li > a {
		display: flex;
		align-items: center;
		width: 100%;
		height: 100%;
		padding-left: 50px;
		padding-right: 0;
		color: var(--wp-text-light);
		text-decoration: none;
		font-family: "Montserrat", sans-serif;
		position: relative;
	}

	/* Rightmost static horizontal grid line segment */
	.wp-navigation-menu-list > li > a::after {
		content: "";
		position: absolute;
		right: 0;
		width: 55px;
		height: 1px;
		background-color: rgba(255, 255, 255, 0.06);
		top: 50%;
		transform: translateY(-50%);
		z-index: 1;
	}

	/* Dynamic horizontal line fill */
	.menu-line-fill {
		flex-grow: 1;
		min-width: 20px;
		height: 1px;
		background-color: rgba(255, 255, 255, 0.06);
		margin-right: 15px;
		z-index: 1;
		transition: all 0.3s ease;
	}

	.wp-navigation-menu-list > li:hover .menu-line-fill {
