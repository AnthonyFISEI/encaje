---
import SEO from '../components/SEO.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { title, description, image } = Astro.props;
const base = import.meta.env.BASE_URL === '/' ? '/' : `${import.meta.env.BASE_URL}/`;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="icon" href={`${base}favicon.ico`} />
		<meta name="generator" content={Astro.generator} />
		<SEO title={title} description={description} image={image} />
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Outfit:wght@100..900&display=swap" rel="stylesheet">
		<!-- Google Material Icons -->
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Outlined" rel="stylesheet" />
	</head>
	<body>
		<!-- Premium Glassmorphic Header -->
		<header class="site-header">
			<div class="header-container">
				<a href={base} class="logo">
					<!-- <span class="logo-accent">E</span>NCAJE -->
					<img src={`${base}logo.svg`} alt="ENCAJE" class="logo-img" />
				</a>
				<nav class="nav-menu">
					<a href={base} class="nav-link">Inicio</a>
					<a href={`${base}proyectos`} class="nav-link">Proyectos</a>
					<a href={`${base}blog`} class="nav-link">Blog</a>
					<a href={`${base}quienes-somos`} class="nav-link">Quienes Somos</a>
					<a href={`${base}contacto`} class="nav-link">Contacto</a>
				</nav>
			</div>
		</header>

		<!-- Main Content Wrapper -->
		<div class="content-wrapper">
			<slot />
		</div>

		<!-- Premium Footer -->
		<footer class="site-footer">
			<div class="footer-container">
				<div class="footer-brand">
					<a href={base} class="logo">
						<!-- <span class="logo-accent">E</span>NCAJE -->
						<img src={`${base}logo.svg`} alt="ENCAJE" class="logo-img" />
					</a>
					<p>Construyendo el futuro con precisión, diseño y calidad arquitectónica.</p>
				</div>
				<div class="footer-links">
					<h4>Navegación</h4>
					<a href={base}>Inicio</a>
					<a href={`${base}proyectos`}>Proyectos</a>
					<a href={`${base}blog`}>Blog</a>
					<a href={`${base}quienes-somos`}>Quienes Somos</a>
					<a href={`${base}contacto`}>Contacto</a>
				</div>
				<div class="footer-info">
					<h4>Contacto</h4>
					<p>Quito, Ecuador</p>
					<p>info@encaje.ec</p>
				</div>
			</div>
			<div class="footer-bottom">
				<p>&copy; {new Date().getFullYear()} ENCAJE. Todos los derechos reservados.</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--bg-dark: #242424;
		--bg-slate: #272727;
		--bg-card: rgba(61, 61, 61, 0.45);
		--border-card: rgba(212, 175, 55, 0.15);
		--border-card-hover: rgba(212, 175, 55, 0.4);
		--primary: #d6a33b; /* Gold accent matching replica */
		--primary-hover: #f3cf65;
		--secondary: #b58918;
		--text-light: #ffffff;
		--text-muted: rgba(255, 255, 255, 0.8);
		--font-heading: 'Outfit', sans-serif;
		--font-body: 'Montserrat', sans-serif;
		--transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
	}

	*, *::before, *::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html,
	body {
		background-color: var(--bg-dark);
		color: var(--text-light);
		font-family: var(--font-body);
		line-height: 1.6;
		overflow-x: hidden;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	/* Glassmorphic Header Styling */
	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 100;
		background: rgba(36, 36, 36, 0.75);
		backdrop-filter: blur(16px) saturate(180%);
		-webkit-backdrop-filter: blur(16px) saturate(180%);
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}

	.header-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1.25rem 2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo {
		font-family: var(--font-heading);
		font-weight: 800;
		font-size: 1.8rem;
		letter-spacing: 0.15em;
		color: var(--text-light);
		text-decoration: none;
		display: flex;
		align-items: center;
		transition: var(--transition-smooth);
	}

	.logo-accent {
		color: var(--primary);
		text-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
	}

	.logo-img {
		height: 5.5rem;
		width: auto;
		aspect-ratio: 652 / 254;
		display: block;
	}

	.nav-menu {
		display: flex;
		gap: 2.5rem;
	}

	.nav-link {
		color: var(--text-muted);
		text-decoration: none;
		font-family: var(--font-heading);
		font-weight: 500;
		font-size: 1.05rem;
		letter-spacing: 0.05em;
		transition: var(--transition-smooth);
		position: relative;
		padding: 0.25rem 0;
	}

	.nav-link::after {
		content: '';
		position: absolute;
		bottom: 0;
		left: 0;
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, var(--primary), var(--secondary));
		transition: var(--transition-smooth);
		box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
	}

	.nav-link:hover {
		color: var(--text-light);
	}

	.nav-link:hover::after {
		width: 100%;
	}

	.content-wrapper {
		margin-top: 9rem; /* Offset for fixed header */
		flex: 1;
	}

	/* Footer Styling */
	.site-footer {
		background: #1b1b1b;
		border-top: 1px solid rgba(255, 255, 255, 0.03);
		padding: 4rem 2rem 2rem;
		margin-top: 6rem;
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 4rem;
	}

	@media (max-width: 768px) {
		.footer-container {
			grid-template-columns: 1fr;
			gap: 2.5rem;
		}
		.header-container {
			flex-direction: column;
			gap: 1rem;
		}
	}

	.footer-brand p {
		color: var(--text-muted);
		margin-top: 1rem;
		max-width: 350px;
		font-size: 0.95rem;
	}

	.footer-links h4, .footer-info h4 {
		font-family: var(--font-heading);
		font-size: 1.15rem;
		color: var(--primary);
		margin-bottom: 1.25rem;
		letter-spacing: 0.05em;
	}

	.footer-links {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer-links a {
		color: var(--text-muted);
		text-decoration: none;
		transition: var(--transition-smooth);
		font-size: 0.95rem;
	}

	.footer-links a:hover {
		color: var(--primary);
		padding-left: 5px;
	}

	.footer-info p {
		color: var(--text-muted);
		margin-bottom: 0.75rem;
		font-size: 0.95rem;
	}

	.footer-bottom {
		max-width: 1200px;
		margin: 3rem auto 0;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		text-align: center;
		color: var(--text-muted);
		font-size: 0.85rem;
	}
</style>
