---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="quienes-somos-page">
    <!-- Hero Section -->
    <section class="about-hero" style="background-image: linear-gradient(to bottom, rgba(36, 36, 36, 0.4) 0%, rgba(36, 36, 36, 0.85) 100%), url('https://encaje.ec/wp-content/uploads/2025/02/BANNER_QUIENES_SOMOS.jpg');">
      <div class="hero-content">
        <span class="hero-tagline">CONÓCENOS</span>
        <h1>Quiénes Somos</h1>
        <ul class="breadcrumbs">
          <li><a href="/">Inicio</a></li>
          <li class="separator">/</li>
          <li class="active">Quiénes Somos</li>
        </ul>
      </div>
    </section>

    <!-- Company Bio / History Section -->
    <section class="bio-section">
      <div class="section-container">
        <div class="bio-grid">
          <!-- Images Collage -->
          <div class="bio-images-collage">
            <div class="collage-track">
              <div class="collage-item main-img">
                <img src="https://encaje.ec/wp-content/uploads/2025/02/03_SECCION_ACERCADE.jpg" alt="Obra de Construcción Principal" class="premium-shadow" />
              </div>
              <div class="collage-subgroup">
                <div class="collage-item sub-img">
                  <img src="https://encaje.ec/wp-content/uploads/2025/02/01_SECCION_ACERCADE.jpg" alt="Detalle de Obra" class="premium-shadow" />
                </div>
                <div class="collage-item sub-img">
                  <img src="https://encaje.ec/wp-content/uploads/2025/02/02_SECCION_ACERCADE.jpg" alt="Materiales" class="premium-shadow" />
                </div>
              </div>
            </div>
          </div>

          <!-- Description Text -->
          <div class="bio-content">
            <h2 class="section-title">Innovación, Honestidad y Rigor Técnico</h2>
            <div class="gold-bar"></div>
            <p class="bio-paragraph">
              Encaje es una empresa fundada en 2017, conformada por un equipo comprometido que integra arquitectura e ingeniería para ofrecer soluciones constructivas eficientes. Nos apasiona resolver problemas de manera honesta, innovadora y confiable, desafiando conceptos, procedimientos y tradiciones. Buscamos que nuestros clientes confíen en nuestra capacidad de innovación, llevándola a cabo con eficiencia en materiales, energía, conceptualización e implementación de proyectos urbanos, siempre considerando el impacto en el entorno y la transformación del entorno.
            </p>
            <p class="bio-paragraph highlight-box">
              Nos enorgullece haber contribuido al embellecimiento de la ciudad a través de diversos proyectos que mejoran su entorno, creando espacios que fomentan la belleza y el bienestar en la comunidad. Un proyecto arquitectónico bien resuelto irradia vida, inspira y genera un ambiente agradable para vivir, trabajar y crear.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="services-section">
      <div class="section-container">
        <div class="services-header">
          <span class="section-tagline">NUESTROS SERVICIOS</span>
          <h2 class="section-title-center">Especialidades de Alta Gama</h2>
          <div class="gold-bar-center"></div>
        </div>

        <div class="services-grid">
          <!-- Card 1 -->
          <div class="service-card">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="service-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
              </svg>
            </div>
            <h3>DISEÑO ARQUITECTONICO</h3>
            <p>Concepto e implantación de proyectos desde cero.</p>
          </div>

          <!-- Card 2 -->
          <div class="service-card">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="service-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.67 2.67 0 0 0 21 17.25l-5.83-5.83m-3.75 3.75-2.03-2.03m2.03 2.03h-.02A2.67 2.67 0 0 1 9.5 9.5v-.02m0 0L21 21M9.5 9.5 12 6.5m-2.5 3L6.5 12" />
              </svg>
            </div>
            <h3>CONSTRUCCIÓN</h3>
            <p>Entregar soluciones constructivas eficientes.</p>
          </div>

          <!-- Card 3 -->
          <div class="service-card">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="service-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.251 2.251 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z" />
              </svg>
            </div>
            <h3>ASESORAMIENTO TÉCNICO</h3>
            <p>Brindamos orientación y conocimientos técnicos al cliente.</p>
          </div>

          <!-- Card 4 -->
          <div class="service-card featured">
            <div class="service-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="service-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 0 0-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z" />
              </svg>
            </div>
            <h3>URBANISMO</h3>
            <p>Construimos desde la responsabilidad social de la arquitectura y la ingeniería.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Methodology / Diferenciadores Section -->
    <section class="diff-section">
      <div class="section-container">
        <div class="services-header">
          <span class="section-tagline">NUESTRO VALOR</span>
          <h2 class="section-title-center">Pilares Diferenciadores</h2>
          <div class="gold-bar-center"></div>
        </div>

        <div class="diff-grid">
          <!-- Item 1 -->
          <div class="diff-card">
            <div class="diff-image-box">
              <img src="https://encaje.ec/wp-content/uploads/2025/02/04_SECCION_METODOLOGIA.jpg" alt="Metodología de Proyección" />
              <div class="diff-card-overlay"></div>
            </div>
            <div class="diff-info">
              <div class="diff-number">01</div>
              <h3>PROYECTAMOS</h3>
              <p>Y construimos desde la responsabilidad social de la arquitectura y la ingeniería con el entorno y la sociedad.</p>
            </div>
          </div>

          <!-- Item 2 -->
          <div class="diff-card">
            <div class="diff-image-box">
              <img src="https://encaje.ec/wp-content/uploads/2025/02/05_SECCION_METODOLOGIA.jpg.jpg" alt="Filosofía Encaje" />
              <div class="diff-card-overlay"></div>
            </div>
            <div class="diff-info">
              <div class="diff-number">02</div>
              <h3>CREEMOS</h3>
              <p>La Arquitectura y la Ingeniería deben ser accesibles para todos, no solo para quienes pueden costearlas, ya que las soluciones constructivas eficientes deben beneficiar principalmente a los más necesitados.</p>
            </div>
          </div>

          <!-- Item 3 -->
          <div class="diff-card">
            <div class="diff-image-box">
              <img src="https://encaje.ec/wp-content/uploads/2025/02/06_SECCION_METODOLOGIA.jpg.jpg" alt="Metodología de Creación" />
              <div class="diff-card-overlay"></div>
            </div>
            <div class="diff-info">
              <div class="diff-number">03</div>
              <h3>CREAMOS</h3>
              <p>Proyectos arquitectónicos y de ingeniería propios que ofrezcan soluciones accesibles para quienes buscan su primera vivienda, ya sea mediante crédito o ahorros.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Closing Banner / Call to action background -->
    <section class="closing-banner" style="background-image: linear-gradient(to top, rgba(36,36,36,0.95), rgba(36,36,36,0.3)), url('https://encaje.ec/wp-content/uploads/2025/02/CIERRE_BANER_QUIENESSOMOS.jpg');">
      <div class="closing-content">
        <h2>¿Listo para proyectar tu obra?</h2>
        <p>Permítenos acompañarte con la máxima rigurosidad técnica y calidad estética.</p>
        <a href="/contacto" class="closing-btn">
          <span>Contáctanos</span>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="btn-arrow">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  .quienes-somos-page {
    background-color: var(--bg-dark);
  }

  /* Hero Styling */
  .about-hero {
    position: relative;
    padding: 12rem 2rem 8rem;
    text-align: center;
    background-size: cover;
    background-position: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .about-hero h1 {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, var(--text-light) 40%, rgba(241, 245, 249, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-transform: uppercase;
  }

  /* Breadcrumbs */
  .breadcrumbs {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(27, 27, 27, 0.6);
    padding: 0.5rem 1.5rem;
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 0.9rem;
  }

  .breadcrumbs a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 500;
    transition: var(--transition-smooth);
  }

  .breadcrumbs a:hover {
    color: var(--primary);
  }

  .breadcrumbs .separator {
    color: rgba(255, 255, 255, 0.25);
  }

  .breadcrumbs .active {
    color: var(--primary);
    font-weight: 600;
    font-family: var(--font-heading);
  }

  /* Bio Section Styling */
  .bio-section {
    padding: 8rem 2rem;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .bio-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 5rem;
    align-items: center;
  }

  /* Collage System */
  .bio-images-collage {
    position: relative;
  }

  .collage-track {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.5rem;
  }

  .collage-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: var(--transition-smooth);
  }

  .collage-item:hover img {
    transform: scale(1.02);
    border-color: rgba(212, 175, 55, 0.3);
  }

  .main-img {
    aspect-ratio: 4/5;
  }

  .collage-subgroup {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: space-between;
  }

  .sub-img {
    aspect-ratio: 1/1;
  }

  .premium-shadow {
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
  }

  /* Bio Text Content */
  .bio-content {
    font-family: var(--font-body);
  }

  .section-title {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .gold-bar {
    width: 60px;
    height: 4px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    margin-bottom: 2rem;
    border-radius: 2px;
  }

  .bio-paragraph {
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .highlight-box {
    background: rgba(212, 175, 55, 0.04);
    border-left: 3px solid var(--primary);
    padding: 1.5rem 2rem;
    border-radius: 0 12px 12px 0;
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.7;
    margin-top: 2rem;
    color: var(--text-light);
  }

  /* Services Section */
  .services-section {
    padding: 8rem 2rem;
    background-color: var(--bg-slate);
    border-top: 1px solid rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid rgba(255, 255, 255, 0.02);
  }

  .services-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-tagline {
    font-family: var(--font-heading);
    color: var(--primary);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.25em;
    display: block;
    margin-bottom: 0.75rem;
  }

  .section-title-center {
    font-family: var(--font-heading);
    font-size: 2.8rem;
    font-weight: 800;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  .gold-bar-center {
    width: 50px;
    height: 4px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    margin: 0 auto;
    border-radius: 2px;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
  }

  /* Service Cards */
  .service-card {
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    transition: var(--transition-smooth);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .service-card:hover {
    transform: translateY(-5px);
    border-color: var(--border-card-hover);
    box-shadow: 0 15px 35px rgba(212, 175, 55, 0.05);
  }

  /* Highlight/featured service cards */
  .service-card.featured {
    border-color: rgba(212, 175, 55, 0.3);
    background: radial-gradient(circle at top right, rgba(212, 175, 55, 0.06), var(--bg-card));
  }

  .service-card.featured:hover {
    border-color: var(--primary);
  }

  .service-icon-box {
    width: 60px;
    height: 60px;
    background: rgba(212, 175, 55, 0.1);
    border: 1px solid rgba(212, 175, 55, 0.25);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 2rem;
    color: var(--primary);
    transition: var(--transition-smooth);
  }

  .service-card:hover .service-icon-box {
    background: var(--primary);
    color: var(--bg-dark);
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
    transform: scale(1.05);
  }

  .service-icon {
    width: 1.8rem;
    height: 1.8rem;
  }

  .service-card h3 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
    color: var(--text-light);
  }

  .service-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    font-weight: 300;
  }

  /* Differenciadores Section */
  .diff-section {
    padding: 8rem 2rem;
  }

  .diff-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  .diff-card {
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 20px;
    overflow: hidden;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .diff-card:hover {
    transform: translateY(-8px);
    border-color: var(--border-card-hover);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .diff-image-box {
    position: relative;
    aspect-ratio: 16/10;
    overflow: hidden;
  }

  .diff-image-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .diff-card:hover .diff-image-box img {
    transform: scale(1.08);
  }

  .diff-card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent 40%, rgba(36, 36, 36, 0.8) 100%);
  }

  .diff-info {
    padding: 2.5rem 2rem;
    position: relative;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .diff-number {
    position: absolute;
    top: -2.5rem;
    right: 2rem;
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 900;
    color: rgba(212, 175, 55, 0.15);
    line-height: 1;
    transition: var(--transition-smooth);
  }

  .diff-card:hover .diff-number {
    color: var(--primary);
    transform: scale(1.1);
  }

  .diff-info h3 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-light);
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .diff-info p {
    color: var(--text-muted);
    font-size: 0.98rem;
    line-height: 1.65;
    font-weight: 300;
    margin: 0;
  }

  /* Closing Banner */
  .closing-banner {
    position: relative;
    padding: 10rem 2rem;
    text-align: center;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .closing-content {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .closing-content h2 {
    font-family: var(--font-heading);
    font-size: 3.2rem;
    font-weight: 800;
    color: var(--text-light);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .closing-content p {
    color: var(--text-muted);
    font-size: 1.25rem;
    font-weight: 300;
    margin-bottom: 3rem;
  }

  /* Premium Button */
  .closing-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--primary);
    color: var(--bg-dark);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    padding: 1.1rem 2.2rem;
    border-radius: 40px;
    box-shadow: 0 10px 25px rgba(212, 175, 55, 0.3);
    transition: var(--transition-smooth);
  }

  .closing-btn:hover {
    background: var(--primary-hover);
    transform: translateY(-3px);
    box-shadow: 0 15px 35px rgba(212, 175, 55, 0.5);
  }

  .btn-arrow {
    width: 1.2rem;
    height: 1.2rem;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .closing-btn:hover .btn-arrow {
    transform: translateX(6px);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .bio-grid {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .diff-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 768px) {
    .about-hero h1 {
      font-size: 3rem;
    }

    .closing-content h2 {
      font-size: 2.2rem;
    }

    .closing-content p {
      font-size: 1.1rem;
    }

    .diff-grid {
      grid-template-columns: 1fr;
    }

    .bio-grid {
      gap: 3rem;
    }

    .section-title-center {
      font-size: 2.2rem;
    }

    .section-title {
      font-size: 2rem;
    }
  }
</style>
