---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL === '/' ? '/' : `${import.meta.env.BASE_URL}/`;
// Fetch projects from local Headless WordPress REST API
const BACKEND_URL = import.meta.env.WORDPRESS_API_URL || "http://encaje-wp.test";
let projects = [];
let errorMsg = null;

try {
  const response = await fetch(`${BACKEND_URL}/wp-json/wp/v2/projects?_embed`);
  if (response.ok) {
    projects = await response.json();
  } else {
    errorMsg = `Error al conectar con el backend (Código: ${response.status})`;
  }
} catch (e) {
  errorMsg = `No se pudo conectar al servidor de WordPress (${BACKEND_URL}). Asegúrate de que esté encendido.`;
  console.error(e);
}
---

<Layout>
  <main class="projects-page">
    <!-- Hero Section -->
    <section class="projects-hero" style="background-image: linear-gradient(to bottom, rgba(36, 36, 36, 0.45) 0%, rgba(36, 36, 36, 0.85) 100%), url('https://encaje.ec/wp-content/uploads/2025/02/BANNER_PROYECTOS.jpg');">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <span class="hero-tagline">DISEÑO Y PRECISIÓN</span>
        <h1>Nuestros Proyectos</h1>
        <ul class="breadcrumbs">
          <li><a href={base}>Inicio</a></li>
          <li class="separator">/</li>
          <li class="active">Proyectos</li>
        </ul>
      </div>
    </section>

    <!-- Projects Grid Section -->
    <section class="projects-section">
      <div class="section-container">
        {errorMsg ? (
          <div class="error-card">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="error-icon">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
            </svg>
            <p>{errorMsg}</p>
          </div>
        ) : (
          <div class="projects-grid">
            {projects.map((project) => {
              // Extract featured media URL safely
              const media = project._embedded?.['wp:featuredmedia']?.[0];
              const imageUrl = media?.source_url || '/placeholder.jpg'; 
              const altText = media?.alt_text || project.title.rendered;
              
              return (
                <article class="project-card">
                  <div class="card-image-wrapper">
                    <img src={imageUrl} alt={altText} class="card-image" loading="lazy" />
                    <div class="card-overlay">
                      <a href={`${base}proyectos/${project.slug}`} class="view-btn">
                        Ver Detalles
                      </a>
                    </div>
                  </div>
                  <div class="card-info">
                    <h2 class="project-title" set:html={project.title.rendered}></h2>
                    <p class="project-desc">Solución constructiva premium que destaca por su innovación estructural y acabados de primera.</p>
                    <a href={`${base}proyectos/${project.slug}`} class="card-link">
                      <span>Explorar Obra</span>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="arrow-icon">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                      </svg>
                    </a>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>
    </section>
  </main>
</Layout>

<style>
  .projects-page {
    background-color: var(--bg-dark);
  }

  /* Hero Section Styling */
  .projects-hero {
    position: relative;
    padding: 12rem 2rem 8rem;
    text-align: center;
    background-size: cover;
    background-position: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.2);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-tagline {
    font-family: var(--font-heading);
    color: var(--primary);
    font-weight: 700;
    font-size: 0.9rem;
    letter-spacing: 0.3em;
    display: block;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .projects-hero h1 {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--text-light) 30%, rgba(241, 245, 249, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-transform: uppercase;
  }

  /* Breadcrumbs */
  .breadcrumbs {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(27, 27, 27, 0.6);
    padding: 0.5rem 1.5rem;
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 0.9rem;
  }

  .breadcrumbs a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 500;
    transition: var(--transition-smooth);
  }

  .breadcrumbs a:hover {
    color: var(--primary);
  }

  .breadcrumbs .separator {
    color: rgba(255, 255, 255, 0.25);
  }

  .breadcrumbs .active {
    color: var(--primary);
    font-weight: 600;
    font-family: var(--font-heading);
  }

  /* Grid Section */
  .projects-section {
    padding: 6rem 2rem;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2.5rem;
  }

  @media (max-width: 640px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
    .projects-hero h1 {
      font-size: 2.5rem;
    }
  }

  /* Card Styling (Premium Glassmorphic and Animated) */
  .project-card {
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 16px;
    overflow: hidden;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: var(--border-card-hover);
    box-shadow: 0 20px 40px rgba(212, 175, 55, 0.08);
  }

  .card-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #1b1b1b;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-card:hover .card-image {
    transform: scale(1.08);
  }

  .card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(36, 36, 36, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transition: var(--transition-smooth);
  }

  .card-image-wrapper:hover .card-overlay {
    opacity: 1;
  }

  .view-btn {
    font-family: var(--font-heading);
    font-weight: 600;
    color: var(--bg-dark);
    background: var(--primary);
    text-decoration: none;
    padding: 0.8rem 1.6rem;
    border-radius: 30px;
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
    transform: translateY(15px);
    transition: var(--transition-smooth);
  }

  .card-image-wrapper:hover .view-btn {
    transform: translateY(0);
  }

  .view-btn:hover {
    background: var(--primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 0 25px rgba(212, 175, 55, 0.6);
  }

  .card-info {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .project-title {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-light);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .project-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    font-family: var(--font-heading);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    width: fit-content;
    transition: var(--transition-smooth);
  }

  .arrow-icon {
    width: 1.1rem;
    height: 1.1rem;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .card-link:hover {
    color: var(--primary-hover);
  }

  .card-link:hover .arrow-icon {
    transform: translateX(6px);
  }

  /* Error Card styling */
  .error-card {
    background: rgba(239, 68, 68, 0.05);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 12px;
    padding: 2.5rem;
    text-align: center;
    max-width: 600px;
    margin: 4rem auto;
  }

  .error-icon {
    width: 3rem;
    height: 3rem;
    color: #ef4444;
    margin: 0 auto 1rem;
  }

  .error-card p {
    color: var(--text-light);
    font-size: 1.1rem;
    line-height: 1.6;
  }
</style>
