---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL === '/' ? '/' : `${import.meta.env.BASE_URL}/`;
// Enable Static Site Generation (SSG) paths
export async function getStaticPaths() {
  const BACKEND_URL = import.meta.env.WORDPRESS_API_URL || "http://encaje-wp.test";
  try {
    const response = await fetch(`${BACKEND_URL}/wp-json/wp/v2/projects?_embed`);
    if (!response.ok) {
      return [];
    }
    const projects = await response.json();
    return projects.map((project) => ({
      params: { slug: project.slug },
      props: { project },
    }));
  } catch (e) {
    console.error("Error generating static paths for projects:", e);
    return [];
  }
}

const { project } = Astro.props;

// If project is not found (e.g. build error or empty paths)
if (!project) {
  return Astro.redirect(`${base}proyectos`);
}

// Extract featured image
const media = project._embedded?.['wp:featuredmedia']?.[0];
const imageUrl = media?.source_url || '/placeholder.jpg';
const imageAlt = media?.alt_text || project.title.rendered;

// Clean up shortcodes (like [rev_slider ...]) from the WordPress content
const cleanContent = project.content.rendered.replace(/\[\/?[^\]]+\]/g, '');

// Extract Yoast SEO fields if available, otherwise use defaults
const seoTitle = project.yoast_head_json?.title || `${project.title.rendered} | Encaje`;
const seoDescription = project.yoast_head_json?.description || project.yoast_head_json?.og_description || `Conoce los detalles y soluciones técnicas del proyecto ${project.title.rendered} de Encaje.`;
const seoImage = project.yoast_head_json?.og_image?.[0]?.url || imageUrl;
---

<Layout title={seoTitle} description={seoDescription} image={seoImage}>
  <main class="project-detail-page">
    <!-- Hero Banner -->
    <section class="detail-hero" style={`background-image: linear-gradient(to bottom, rgba(36, 36, 36, 0.4), rgba(36, 36, 36, 0.95)), url(${imageUrl});`}>
      <div class="hero-container">
        <a href={`${base}proyectos`} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="back-arrow">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          <span>Volver a Proyectos</span>
        </a>
        <h1 class="project-title" set:html={project.title.rendered}></h1>
      </div>
    </section>

    <!-- Content Section -->
    <section class="detail-content-section">
      <div class="content-container">
        <!-- Main Image Card -->
        <div class="featured-media-card">
          <Image src={imageUrl} alt={imageAlt} class="main-image" width={900} height={560} />
        </div>

        <!-- Rich Text content -->
        <article class="project-rich-content" set:html={cleanContent}>
        </article>
      </div>
    </section>
  </main>
</Layout>

<style>
  .project-detail-page {
    background-color: var(--bg-dark);
    min-height: 100vh;
  }

  /* Hero Banner Styling */
  .detail-hero {
    height: 60vh;
    min-height: 400px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: flex-end;
    position: relative;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-container {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    z-index: 10;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    transition: var(--transition-smooth);
    width: fit-content;
  }

  .back-link:hover {
    color: var(--primary-hover);
  }

  .back-arrow {
    width: 1.1rem;
    height: 1.1rem;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .back-link:hover .back-arrow {
    transform: translateX(-5px);
  }

  .project-title {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 800;
    color: var(--text-light);
    letter-spacing: -0.02em;
    line-height: 1.1;
    text-shadow: 0 4px 15px rgba(0, 0, 0, 0.6);
  }

  @media (max-width: 768px) {
    .project-title {
      font-size: 2.5rem;
    }
    .detail-hero {
      height: 45vh;
    }
  }

  /* Content Container styling */
  .detail-content-section {
    padding: 4rem 2rem;
  }

  .content-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .featured-media-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border-card);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    margin-top: -8rem;
    margin-bottom: 4rem;
    position: relative;
    z-index: 20;
    background: #1b1b1b;
  }

  .main-image {
    width: 100%;
    height: auto;
    display: block;
    max-height: 600px;
    object-fit: cover;
  }

  /* Global child styles for clean content */
  .project-rich-content {
    line-height: 1.8;
  }

  /* Styling headers from WordPress */
  .project-rich-content :global(h2), 
  .project-rich-content :global(h3) {
    font-family: var(--font-heading);
    color: var(--text-light);
    font-weight: 700;
    font-size: 2.2rem;
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .project-rich-content :global(h2::after) {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 3px;
    background: var(--primary);
    border-radius: 2px;
  }

  /* Styling paragraph content */
  .project-rich-content :global(p) {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 1.8rem;
  }

  /* Styling Ficha Técnica list */
  .project-rich-content :global(ul) {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    padding: 2.5rem;
    border-radius: 16px;
    margin: 3rem 0;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.01);
  }

  .project-rich-content :global(li) {
    border-left: 2px solid var(--primary);
    padding-left: 1.25rem;
    font-family: var(--font-body);
    color: var(--text-light);
    font-size: 1.1rem;
    line-height: 1.4;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  /* Target first line/word as label */
  .project-rich-content :global(li) {
    white-space: pre-line;
  }
</style>
