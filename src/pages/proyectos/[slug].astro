---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';

const base = import.meta.env.BASE_URL === '/' ? '/' : `${import.meta.env.BASE_URL}/`;
// Enable Static Site Generation (SSG) paths
export async function getStaticPaths() {
  const BACKEND_URL = import.meta.env.WORDPRESS_API_URL || "http://encaje-wp.test";
  try {
    const response = await fetch(`${BACKEND_URL}/wp-json/wp/v2/projects?_embed`);
    if (!response.ok) {
      return [];
    }
    const projects = await response.json();
    return projects.map((project) => ({
      params: { slug: project.slug },
      props: { project },
    }));
  } catch (e) {
    console.error("Error generating static paths for projects:", e);
    return [];
  }
}

const { project } = Astro.props;

// If project is not found (e.g. build error or empty paths)
if (!project) {
  return Astro.redirect(`${base}proyectos`);
}

// Extract featured image
const media = project._embedded?.['wp:featuredmedia']?.[0];
const imageUrl = media?.source_url || '/placeholder.jpg';
const imageAlt = media?.alt_text || project.title.rendered;

// Clean up shortcodes (like [rev_slider ...]) from the WordPress content
let cleanContent = project.content.rendered.replace(/\[\/?[^\]]+\]/g, '');

const hasStructuredData = (project.acf && (project.acf.estilo || project.acf.tipo_obra || project.acf.ubicacion || project.acf.cliente || project.acf.descripcion)) || 
  (project.planimetria_ambientada_gallery && project.planimetria_ambientada_gallery.length > 0) || 
  (project.planimetria_arquitectonica_gallery && project.planimetria_arquitectonica_gallery.length > 0) || 
  (project.volumetria_gallery && project.volumetria_gallery.length > 0) || 
  (project.resultados_gallery && project.resultados_gallery.length > 0) ||
  (project.renders_gallery && project.renders_gallery.length > 0) || 
  (project.planos_gallery && project.planos_gallery.length > 0);

if (hasStructuredData) {
  // If we have structured data, strip out any legacy lists, images, figures, and gallery headings from the description
  cleanContent = cleanContent
    .replace(/<img[^>]*>/gi, '') // Remove all image tags
    .replace(/<figure[^>]*>[\s\S]*?<\/figure>/gi, '') // Remove all figures (like Gutenberg or Elementor galleries/images)
    .replace(/<ul[^>]*>[\s\S]*?<\/ul>/gi, '') // Remove any lists (like Ficha Técnica list)
    .replace(/<h[1-6][^>]*>[\s\S]*?<\/h[1-6]>/gi, (match) => {
      // Remove headings that match typical Elementor gallery/spec section names
      const rawText = match.replace(/<[^>]*>/g, '').trim().toLowerCase();
      const text = rawText.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
      if (
        text.includes('ficha') || 
        text.includes('render') || 
        text.includes('plano') || 
        text.includes('planimetri') || 
        text.includes('resultado') || 
        text.includes('proyecto')
      ) {
        return '';
      }
      return match;
    });
}

// Extract Yoast SEO fields if available, otherwise use defaults
const seoTitle = project.yoast_head_json?.title || `${project.title.rendered} | Encaje`;
const seoDescription = project.yoast_head_json?.description || project.yoast_head_json?.og_description || `Conoce los detalles y soluciones técnicas del proyecto ${project.title.rendered} de Encaje.`;
const seoImage = project.yoast_head_json?.og_image?.[0]?.url || imageUrl;
---

<Layout title={seoTitle} description={seoDescription} image={seoImage}>
  <main class="project-detail-page">
    <!-- Hero Banner -->
    <section class="detail-hero" style={`background-image: linear-gradient(to bottom, rgba(36, 36, 36, 0.4), rgba(36, 36, 36, 0.95)), url(${imageUrl});`}>
      <div class="hero-container">
        <a href={`${base}proyectos`} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="back-arrow">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          <span>Volver a Proyectos</span>
        </a>
        <h1 class="project-title" set:html={project.title.rendered}></h1>
      </div>
    </section>

    <!-- Content Section -->
    <section class="detail-content-section">
      <div class="content-container">
        <!-- Main Image Card -->
        <div class="featured-media-card">
          <Image src={imageUrl} alt={imageAlt} class="main-image" width={900} height={560} />
        </div>

        {/* Check if we have structured data. If so, display it in a modern grid. */}
        {((project.acf && (project.acf.estilo || project.acf.tipo_obra || project.acf.ubicacion || project.acf.cliente)) || 
          (project.renders_gallery && project.renders_gallery.length > 0) || 
          (project.planos_gallery && project.planos_gallery.length > 0) || 
          (project.resultados_gallery && project.resultados_gallery.length > 0)) ? (
          
          <div class="structured-project-content">
            <!-- Grid: Technical specifications and main description -->
            <div class="project-info-grid">
              <!-- Ficha Técnica -->
              <div class="project-specs-card">
                <h2 class="section-subtitle">Ficha Técnica</h2>
                <ul class="specs-list">
                  {project.acf?.estilo && (
                    <li>
                      <span class="spec-label">Estilo</span>
                      <span class="spec-val">{project.acf.estilo}</span>
                    </li>
                  )}
                  {project.acf?.tipo_obra && (
                    <li>
                      <span class="spec-label">Tipo de Obra</span>
                      <span class="spec-val">{project.acf.tipo_obra}</span>
                    </li>
                  )}
                  {project.acf?.ubicacion && (
                    <li>
                      <span class="spec-label">Ubicación</span>
                      <span class="spec-val">{project.acf.ubicacion}</span>
                    </li>
                  )}
                  {project.acf?.cliente && (
                    <li>
                      <span class="spec-label">Cliente</span>
                      <span class="spec-val">{project.acf.cliente}</span>
                    </li>
                  )}
                </ul>
              </div>

              <!-- Reseña del Proyecto -->
              <div class="project-description-card">
                <h2 class="section-subtitle">El Proyecto</h2>
                <div class="project-desc-text" set:html={project.acf?.descripcion ? project.acf.descripcion : cleanContent} />
              </div>
            </div>

            <!-- Galleries Section -->
            {project.renders_gallery && project.renders_gallery.length > 0 && (
              <div class="gallery-section">
                <h2 class="gallery-section-title">RENDERS</h2>
                <div class="gallery-masonry">
                  {project.renders_gallery.map((img) => (
                    <div class="gallery-card">
                      <a href={img.url} target="_blank" rel="noopener noreferrer" class="gallery-link">
                        <Image src={img.url} alt={img.alt || "Render"} class="gallery-img" width={800} height={530} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.planimetria_ambientada_gallery && project.planimetria_ambientada_gallery.length > 0 && (
              <div class="gallery-section">
                <h2 class="gallery-section-title">PLANIMETRÍA AMBIENTADA</h2>
                <div class="gallery-masonry">
                  {project.planimetria_ambientada_gallery.map((img) => (
                    <div class="gallery-card">
                      <a href={img.url} target="_blank" rel="noopener noreferrer" class="gallery-link">
                        <Image src={img.url} alt={img.alt || "Planimetría Ambientada"} class="gallery-img" width={800} height={530} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.planimetria_arquitectonica_gallery && project.planimetria_arquitectonica_gallery.length > 0 && (
              <div class="gallery-section">
                <h2 class="gallery-section-title">PLANIMETRÍA ARQUITECTÓNICA</h2>
                <div class="gallery-masonry">
                  {project.planimetria_arquitectonica_gallery.map((img) => (
                    <div class="gallery-card">
                      <a href={img.url} target="_blank" rel="noopener noreferrer" class="gallery-link">
                        <Image src={img.url} alt={img.alt || "Planimetría Arquitectónica"} class="gallery-img" width={800} height={530} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.volumetria_gallery && project.volumetria_gallery.length > 0 && (
              <div class="gallery-section">
                <h2 class="gallery-section-title">VOLUMETRÍA</h2>
                <div class="gallery-masonry">
                  {project.volumetria_gallery.map((img) => (
                    <div class="gallery-card">
                      <a href={img.url} target="_blank" rel="noopener noreferrer" class="gallery-link">
                        <Image src={img.url} alt={img.alt || "Volumetría"} class="gallery-img" width={800} height={530} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.resultados_gallery && project.resultados_gallery.length > 0 && (
              <div class="gallery-section">
                <h2 class="gallery-section-title">RESULTADOS</h2>
                <div class="gallery-masonry">
                  {project.resultados_gallery.map((img) => (
                    <div class="gallery-card">
                      <a href={img.url} target="_blank" rel="noopener noreferrer" class="gallery-link">
                        <Image src={img.url} alt={img.alt || "Resultado"} class="gallery-img" width={800} height={530} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Backwards compatibility fallback for plans */}
            {(!project.planimetria_ambientada_gallery || project.planimetria_ambientada_gallery.length === 0) && 
             (!project.planimetria_arquitectonica_gallery || project.planimetria_arquitectonica_gallery.length === 0) && 
             project.planos_gallery && project.planos_gallery.length > 0 && (
              <div class="gallery-section">
                <h2 class="gallery-section-title">PLANOS</h2>
                <div class="gallery-masonry">
                  {project.planos_gallery.map((img) => (
                    <div class="gallery-card">
                      <a href={img.url} target="_blank" rel="noopener noreferrer" class="gallery-link">
                        <Image src={img.url} alt={img.alt || "Plano"} class="gallery-img" width={800} height={530} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        ) : (
          /* Fallback: If no structured data is present, render the HTML directly from WordPress (compatibility mode) */
          <article class="project-rich-content" set:html={cleanContent} />
        )}
      </div>
    </section>
  </main>

  <!-- Lightbox Modal -->
  <div id="lightbox-modal" class="lightbox-modal" aria-hidden="true">
    <span class="lightbox-close">&times;</span>
    <img class="lightbox-content" id="lightbox-img" alt="Lightbox gallery preview" />
    <div id="lightbox-caption" class="lightbox-caption"></div>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('lightbox-modal');
    const modalImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const captionText = document.getElementById('lightbox-caption');
    const closeBtn = document.querySelector('.lightbox-close');

    if (modal && modalImg) {
      const galleryLinks = document.querySelectorAll('.gallery-link, .wp-gallery-item a');
      
      galleryLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const img = link.querySelector('img');
          const fullUrl = link.getAttribute('href');
          if (img && fullUrl) {
            modal.style.display = 'flex';
            // Force reflow
            modal.offsetHeight;
            modal.classList.add('show');
            modalImg.src = fullUrl;
            if (captionText) {
              captionText.textContent = img.getAttribute('alt') || '';
            }
          }
        });
      });

      const closeModal = () => {
        modal.classList.remove('show');
        setTimeout(() => {
          modal.style.display = 'none';
          modalImg.src = '';
        }, 300);
      };

      closeBtn?.addEventListener('click', closeModal);
      modal.addEventListener('click', (e) => {
        if (e.target === modal || e.target === closeBtn) {
          closeModal();
        }
      });
      
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('show')) {
          closeModal();
        }
      });
    }
  });
</script>

<style>
  .project-detail-page {
    background-color: var(--bg-dark);
    min-height: 100vh;
  }

  /* Hero Banner Styling */
  .detail-hero {
    height: 60vh;
    min-height: 400px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: flex-end;
    position: relative;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-container {
    max-width: 1200px;
    width: 100%;
    margin: 0 auto;
    padding: 0 2rem 4rem;
    z-index: 10;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    transition: var(--transition-smooth);
    width: fit-content;
  }

  .back-link:hover {
    color: var(--primary-hover);
  }

  .back-arrow {
    width: 1.1rem;
    height: 1.1rem;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .back-link:hover .back-arrow {
    transform: translateX(-5px);
  }

  .project-title {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 800;
    color: var(--text-light);
    letter-spacing: -0.02em;
    line-height: 1.1;
    text-shadow: 0 4px 15px rgba(0, 0, 0, 0.6);
  }

  @media (max-width: 768px) {
    .project-title {
      font-size: 2.5rem;
    }
    .detail-hero {
      height: 45vh;
    }
  }

  /* Content Container styling */
  .detail-content-section {
    padding: 4rem 2rem;
  }

  .content-container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .featured-media-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--border-card);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    margin-top: -8rem;
    margin-bottom: 4rem;
    position: relative;
    z-index: 20;
    background: #1b1b1b;
  }

  .main-image {
    width: 100%;
    height: auto;
    display: block;
    max-height: 600px;
    object-fit: cover;
  }

  /* Structured Content Styles */
  .project-info-grid {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: 3rem;
    margin-bottom: 4rem;
  }

  @media (max-width: 768px) {
    .project-info-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  .section-subtitle {
    font-family: var(--font-heading);
    color: var(--text-light);
    font-weight: 700;
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    position: relative;
    padding-bottom: 0.5rem;
  }

  .section-subtitle::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 40px;
    height: 3px;
    background: var(--primary);
    border-radius: 2px;
  }

  /* Ficha técnica styling */
  .specs-list {
    list-style: none;
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    padding: 2rem;
    border-radius: 16px;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.01);
  }

  .specs-list li {
    border-left: 2px solid var(--primary);
    padding-left: 1rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .specs-list li:last-child {
    margin-bottom: 0;
  }

  .spec-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    font-weight: 500;
  }

  .spec-val {
    font-size: 1.1rem;
    color: var(--text-light);
    font-weight: 600;
  }

  /* Description styling */
  .project-desc-text {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.8;
    text-align: justify;
    white-space: pre-line;
  }

  .project-desc-text :global(p) {
    margin-bottom: 1.5rem;
    text-align: justify;
    white-space: pre-line;
  }

  .project-desc-text :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Galleries styling */
  .gallery-section {
    margin-top: 5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 3.5rem;
  }

  .gallery-section-title {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-light);
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
    position: relative;
    padding-left: 1rem;
  }

  .gallery-section-title::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10%;
    height: 80%;
    width: 4px;
    background: var(--primary);
    border-radius: 2px;
  }

  .gallery-masonry {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .gallery-card {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--border-card);
    background: #1b1b1b;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
    transition: var(--transition-smooth);
  }

  .gallery-link {
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .gallery-img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.4);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .gallery-card:hover .gallery-img {
    transform: scale(1.05);
  }

  /* Fallback Legacy Styles */
  .project-rich-content {
    line-height: 1.8;
  }

  .project-rich-content :global(h2), 
  .project-rich-content :global(h3) {
    font-family: var(--font-heading);
    color: var(--text-light);
    font-weight: 700;
    font-size: 2.2rem;
    margin-top: 3.5rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .project-rich-content :global(h2::after) {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 3px;
    background: var(--primary);
    border-radius: 2px;
  }

  .project-rich-content :global(p) {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 1.8rem;
  }

  .project-rich-content :global(ul) {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    padding: 2.5rem;
    border-radius: 16px;
    margin: 3rem 0;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: inset 0 0 20px rgba(255, 255, 255, 0.01);
  }

  .project-rich-content :global(li) {
    border-left: 2px solid var(--primary);
    padding-left: 1.25rem;
    font-family: var(--font-body);
    color: var(--text-light);
    font-size: 1.1rem;
    line-height: 1.4;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .project-rich-content :global(li) {
    white-space: pre-line;
  }

  /* Lightbox Modal */
  .lightbox-modal {
    display: none;
    position: fixed;
    z-index: 99999;
    padding-top: 60px;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(0,0,0,0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .lightbox-modal.show {
    opacity: 1;
  }
  .lightbox-content {
    margin: auto;
    display: block;
    max-width: 90%;
    max-height: 80vh;
    object-fit: contain;
    transform: scale(0.95);
    transition: transform 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 40px rgba(0,0,0,0.8);
  }
  .lightbox-modal.show .lightbox-content {
    transform: scale(1);
  }
  .lightbox-close {
    position: absolute;
    top: 30px;
    right: 40px;
    color: #fff;
    font-size: 40px;
    font-weight: 300;
    cursor: pointer;
    transition: 0.3s;
  }
  .lightbox-close:hover {
    color: var(--primary);
  }
  .lightbox-caption {
    position: absolute;
    bottom: 30px;
    width: 100%;
    text-align: center;
    color: #ccc;
    font-size: 14px;
    letter-spacing: 1px;
    font-family: var(--font-body);
  }
</style>
