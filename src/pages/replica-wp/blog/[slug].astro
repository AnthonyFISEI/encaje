---
import LayoutWpReplica from '../../../layouts/LayoutWpReplica.astro';

const base = import.meta.env.BASE_URL === '/' ? '/' : `${import.meta.env.BASE_URL}/`;

export async function getStaticPaths() {
  const BACKEND_URL = import.meta.env.WORDPRESS_API_URL || "http://encaje-wp.test";
  
  const localFallback = [
    { slug: "innovacion-y-sostenibilidad-en-la-arquitectura-moderna" },
    { slug: "planificacion-de-obras-civiles-clave-para-el-exito" },
    { slug: "tendencias-de-diseno-de-interiores-para-espacios-de-trabajo" }
  ];

  try {
    const response = await fetch(`${BACKEND_URL}/wp-json/wp/v2/posts?_embed`);
    if (response.ok) {
      const posts = await response.json();
      return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
      }));
    }
  } catch (e) {
    console.warn("Could not connect to WordPress to generate static paths for replica blog. Using fallbacks.");
  }

  // Fallback paths if offline
  return localFallback.map((item) => {
    const found = [
      {
        title: { rendered: "Innovación y Sostenibilidad en la Arquitectura Moderna" },
        slug: "innovacion-y-sostenibilidad-en-la-arquitectura-moderna",
        date: "2026-06-10T12:00:00",
        excerpt: { rendered: "Exploramos cómo las nuevas tecnologías..." },
        content: { rendered: "<p>La arquitectura moderna se encuentra en un punto de inflexión. El cambio climático y la necesidad de optimizar recursos han impulsado a ingenieros y arquitectos a buscar soluciones más eficientes. En Encaje, proyectamos y construimos con una rigurosa planificación para garantizar que cada obra respete su entorno social y ecológico.</p><p>Materiales reciclados, sistemas de captación de agua y paneles solares integrados en la estructura no son solo tendencias, sino estándares de la edificación del futuro. En este artículo detallamos las mejores prácticas globales y cómo las implementamos en Ecuador.</p><h3>La Importancia de los Materiales Eco-Amigables</h3><p>La selección de materiales es crítica. Elementos como el hormigón celular, la madera certificada y las pinturas libres de compuestos orgánicos volátiles (COVs) reducen drásticamente la huella de carbono de la construcción y mejoran la calidad del aire interior.</p><p>Al planificar nuestros proyectos, evaluamos el ciclo de vida completo de cada material para asegurar un impacto mínimo y una durabilidad máxima.</p>" },
        _embedded: { "wp:featuredmedia": [{ source_url: "https://encaje.ec/wp-content/uploads/2025/02/03-SECCION-NOSOTROS-1.jpg" }] }
      },
      {
        title: { rendered: "Planificación de Obras Civiles: Clave para el Éxito" },
        slug: "planificacion-de-obras-civiles-clave-para-el-exito",
        date: "2026-05-28T09:30:00",
        excerpt: { rendered: "Un desglose detallado de la importancia del control de cronogramas..." },
        content: { rendered: "<p>Todo gran proyecto arquitectónico comienza con una planificación minuciosa. Los desvíos en tiempos y costos suelen ser los principales dolores de cabeza de los desarrolladores. Es por ello que un equipo técnico de alto nivel es indispensable.</p><p>Desde los estudios de suelo hasta los acabados finales, cada etapa requiere supervisión continua y el uso de herramientas tecnológicas modernas para mitigar riesgos. La transparencia y la honestidad en cada fase garantizan obras duraderas y de alta calidad.</p><h3>Optimización de Procesos</h3><p>Utilizar metodologías como BIM (Building Information Modeling) nos permite modelar virtualmente la edificación antes de iniciar la excavación, detectando conflictos de ingeniería y ajustando el presupuesto al milímetro.</p><p>Esto se traduce en obras sin retrasos y con total conformidad con las expectativas del cliente.</p>" },
        _embedded: { "wp:featuredmedia": [{ source_url: "https://encaje.ec/wp-content/uploads/2025/02/03-SECCION-NOSOTROS-2.jpg" }] }
      },
      {
        title: { rendered: "Tendencias de Diseño de Interiores para Espacios de Trabajo" },
        slug: "tendencias-de-diseno-de-interiores-para-espacios-de-trabajo",
        date: "2026-05-15T15:45:00",
        excerpt: { rendered: "Cómo el diseño biofílico y los espacios flexibles..." },
        content: { rendered: "<p>El diseño de oficinas ha evolucionado de cubículos grises a espacios dinámicos y abiertos. Hoy en día se prioriza el bienestar del usuario, introduciendo elementos naturales, luz natural maximizada y áreas de relajación.</p><p>El diseño biofílico, que integra plantas, agua y texturas naturales, ha demostrado reducir el estrés laboral y potenciar la creatividad. En Encaje diseñamos soluciones a medida que combinan la estética con la funcionalidad empresarial.</p><h3>La Revolución de la Flexibilidad</h3><p>Mobiliario modular, salas de reuniones virtuales integradas y zonas híbridas de co-working permiten que las empresas se adapten a las necesidades cambiantes de sus equipos día a día.</p><p>Un buen diseño interior inspira pertenencia y mejora el clima organizacional de forma medible.</p>" },
        _embedded: { "wp:featuredmedia": [{ source_url: "https://encaje.ec/wp-content/uploads/2025/02/03_CIERRE_NOSOTROS.jpg" }] }
      }
    ].find(p => p.slug === item.slug);

    return {
      params: { slug: item.slug },
      props: { post: found }
    };
  });
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect(`${base}replica-wp/blog`);
}

const media = post._embedded?.['wp:featuredmedia']?.[0];
const imageUrl = media?.source_url || 'https://encaje.ec/wp-content/uploads/2025/02/03-SECCION-NOSOTROS-1.jpg';

// Clean shortcodes
const processedContent = post.content.rendered.replace(/\[\/?[^\]]+\]/g, '');

// Yoast SEO
const seoTitle = post.yoast_head_json?.title || `${post.title.rendered} - Encaje (Réplica WordPress)`;
const seoDescription = post.yoast_head_json?.description || post.yoast_head_json?.og_description || `Lee ${post.title.rendered} en la réplica WordPress de Encaje.`;
const seoImage = post.yoast_head_json?.og_image?.[0]?.url || imageUrl;

// Format date helper
const formatDate = (dateString) => {
  const options = { year: 'numeric', month: 'long', day: 'numeric' };
  return new Date(dateString).toLocaleDateString('es-ES', options);
};
---

<LayoutWpReplica title={seoTitle} description={seoDescription} image={seoImage}>
  <main class="wp-replica-detail">
    <!-- Banner Section -->
    <section class="wp-single-banner">
      <div class="wp-banner-container">
        <h1 set:html={post.title.rendered}></h1>
        <p>Noticias y Tendencias &bull; {formatDate(post.date)}</p>
      </div>
    </section>

    <!-- Main Content Section -->
    <section class="wp-single-blog-section">
      <div class="wp-blog-container">
        <!-- Featured Image -->
        <div class="wp-blog-image-box">
          <img src={imageUrl} alt={post.title.rendered} />
        </div>

        <!-- Description -->
        <div class="wp-blog-content-box">
          <article class="wp-blog-content" set:html={processedContent}>
          </article>
        </div>

        <!-- Back link -->
        <div class="wp-back-box">
          <a href={`${base}replica-wp/blog`} class="wp-back-btn">VOLVER AL BLOG</a>
        </div>
      </div>
    </section>
  </main>
</LayoutWpReplica>

<style>
  .wp-replica-detail {
    background-color: var(--wp-bg-dark);
    padding-bottom: 80px;
  }

  /* Single banner */
  .wp-single-banner {
    padding: 120px 0 80px;
    background-color: var(--wp-bg-darker);
    border-bottom: 1px solid #3d3d3d;
    margin-bottom: 60px;
  }

  .wp-banner-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .wp-single-banner h1 {
    font-size: 40px;
    font-weight: 700;
    color: var(--wp-text-light);
    font-family: "Montserrat", sans-serif;
    text-transform: uppercase;
    margin-bottom: 10px;
    line-height: 1.25;
  }

  .wp-single-banner p {
    font-size: 14px;
    color: var(--wp-accent-gold);
    font-family: "Montserrat", sans-serif;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* Layout container */
  .wp-single-blog-section {
    padding: 0 0 40px 0;
  }

  .wp-blog-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .wp-blog-image-box {
    margin-bottom: 40px;
  }

  .wp-blog-image-box img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid #3d3d3d;
  }

  /* Rendered Content styles matching WordPress */
  .wp-blog-content {
    font-family: "Montserrat", sans-serif;
    line-height: 28px;
    font-size: 15px;
    color: var(--wp-text-muted);
  }

  .wp-blog-content :global(h2),
  .wp-blog-content :global(h3) {
    font-size: 24px;
    font-weight: 600;
    color: var(--wp-text-light);
    margin-top: 40px;
    margin-bottom: 20px;
    font-family: "Montserrat", sans-serif;
  }

  .wp-blog-content :global(p) {
    font-size: 15px;
    color: var(--wp-text-muted);
    line-height: 28px;
    margin-bottom: 25px;
    font-weight: 300;
  }

  .wp-blog-content :global(ul),
  .wp-blog-content :global(ol) {
    margin: 20px 0 25px;
    padding-left: 20px;
    color: var(--wp-text-muted);
  }

  .wp-blog-content :global(li) {
    margin-bottom: 10px;
    font-weight: 300;
  }

  /* Back button styling */
  .wp-back-box {
    margin-top: 50px;
    border-top: 1px solid #3d3d3d;
    padding-top: 30px;
  }

  .wp-back-btn {
    display: inline-block;
    color: var(--wp-text-light);
    font-size: 14px;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 2px;
    padding-bottom: 5px;
    border-bottom: 1px solid var(--wp-text-light);
    transition: color 0.2s, border-color 0.2s;
  }

  .wp-back-btn:hover {
    color: var(--wp-accent-gold);
    border-color: var(--wp-accent-gold);
  }
</style>
