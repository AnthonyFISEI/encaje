---
import LayoutWpReplica from '../../layouts/LayoutWpReplica.astro';
import WpSlider from '../../components/WpSlider.astro';

const base = import.meta.env.BASE_URL === '/' ? '/' : `${import.meta.env.BASE_URL}/`;
---

<LayoutWpReplica title="Contacto - Encaje (Réplica WordPress)">
  <main class="wp-contacto-page">
    <!-- Page Banner -->
    <WpSlider location="contacto" />

    <!-- Contact Info Section -->
    <section class="contact-info-section">
      <div class="container">
        <div class="title-box">
          <span></span>
          <h2>Contáctanos</h2>
        </div>
        
        <div class="contact-info-box">
          <div class="row-info">
            <!-- Whatsapp Info -->
            <div class="col-info">
              <div class="contact-info-post">
                <svg aria-hidden="true" class="e-font-icon-svg e-fab-whatsapp" viewBox="0 0 448 512" xmlns="http://www.w3.org/2000/svg">
                  <path fill="currentColor" d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"></path>
                </svg>
                <div class="info-content">
                  <h4>+593 98 311 6325</h4>
                </div>
              </div>
            </div>

            <!-- Email Info -->
            <div class="col-info">
              <div class="contact-info-post">
                <svg aria-hidden="true" class="e-font-icon-svg e-far-envelope" viewBox="0 0 512 512" xmlns="http://www.w3.org/2000/svg">
                  <path fill="currentColor" d="M464 64H48C21.49 64 0 85.49 0 112v288c0 26.51 21.49 48 48 48h416c26.51 0 48-21.49 48-48V112c0-26.51-21.49-48-48-48zm0 48v40.805c-22.422 18.259-58.168 46.651-134.587 106.49-16.841 13.247-50.201 45.072-73.413 44.701-23.208.375-56.579-31.459-73.413-44.701C106.18 199.465 70.425 171.067 48 152.805V112h416zM48 400V214.398c22.914 18.251 55.409 43.862 104.938 82.646 21.857 17.205 60.134 55.186 103.062 54.955 42.717.231 80.509-37.199 103.053-54.947 49.528-38.783 82.032-64.401 104.947-82.653V400H48z"></path>
                </svg>
                <div class="info-content">
                  <h4>info@encaje.ec</h4>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-form-box">
          <div class="row-form">
            <!-- Form Block -->
            <div class="col-lg-8">
              <div id="contact-form">
                <div class="wpcf7">
                  <form action="#" method="post" class="wpcf7-form" onSubmit="event.preventDefault(); alert('Mensaje enviado con éxito (simulación en réplica).');">
                    <h4>Envíanos un mensaje</h4>
                    <div class="row-fields">
                      <div class="col-md-6">
                        <div class="input-line">
                          <label for="your-name"><i class="fas fa-user"></i></label>
                          <input size="40" class="wpcf7-form-control wpcf7-text" placeholder="Nombre" type="text" name="your-name" required />
                        </div>
                        <div class="input-line">
                          <label for="your-email"><i class="far fa-envelope"></i></label>
                          <input size="40" class="wpcf7-form-control wpcf7-text" placeholder="Correo" type="email" name="your-email" required />
                        </div>
                        <div class="input-line">
                          <label for="your-subject"><i class="fas fa-link"></i></label>
                          <input size="40" class="wpcf7-form-control wpcf7-text" placeholder="Asunto" type="text" name="your-subject" required />
                        </div>
                      </div>
                      <div class="col-md-6">
                        <div class="input-line text-area-line">
                          <textarea cols="40" rows="10" class="wpcf7-form-control wpcf7-textarea" placeholder="Mensaje" name="your-message" required></textarea>
                        </div>
                        <div class="submit-line">
                          <input class="wpcf7-form-control wpcf7-submit" type="submit" value="Enviar" />
                        </div>
                      </div>
                    </div>
                  </form>
                </div>
              </div>
            </div>

            <!-- Map Block -->
            <div class="col-lg-4">
              <div id="map">
                <div class="elementor-custom-embed">
                  <iframe frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="https://maps.google.com/maps?q=Quito%2C+Ecuador&t=m&z=14&output=embed&iwloc=near"></iframe>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Cierre Banner Section -->
    <section class="wp-cierre-banner">
      <img src="https://encaje.ec/wp-content/uploads/2025/02/CIERRE_BANNER_CONTACTO.jpg" alt="Cierre Banner Contacto" class="wp-cierre-banner-img" />
    </section>


  </main>
</LayoutWpReplica>

<style>
  .wp-contacto-page {
    background-color: var(--wp-bg-dark);
    font-family: "Montserrat", sans-serif;
  }

  /* Page Banner styling */
  .wp-page-banner {
    padding: 180px 0 100px;
    background-size: cover;
    background-position: center;
    border-bottom: 1px solid #3d3d3d;
    position: relative;
    text-align: center;
  }

  .wp-banner-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .wp-banner-svg-title {
    max-width: 500px;
    width: 100%;
    height: auto;
    margin-bottom: 25px;
    display: inline-block;
  }

  .wp-breadcrumbs {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 10px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.4);
    margin-top: 15px;
  }

  .wp-breadcrumbs a {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: none;
    transition: all 0.2s;
  }

  .wp-breadcrumbs a:hover {
    color: var(--wp-accent-yellow);
  }

  .wp-breadcrumbs li.active {
    color: var(--wp-text-light);
  }

  /* Contact Info Section */
  .contact-info-section {
    padding: 100px 0;
  }

  .container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .title-box {
    text-align: left;
    margin-bottom: 50px;
    position: relative;
  }

  .title-box span {
    display: block;
    width: 30px;
    height: 1px;
    background-color: var(--wp-accent-gold);
    margin-bottom: 15px;
  }

  .title-box h2 {
    font-size: 30px;
    font-weight: 700;
    color: var(--wp-text-light);
    text-transform: uppercase;
    margin: 0;
    letter-spacing: 1px;
  }

  .contact-info-box {
    margin-bottom: 60px;
  }

  .row-info {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 30px;
  }

  .contact-info-post {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 30px;
    border: 1px solid #3d3d3d;
    background-color: var(--wp-bg-darker);
    min-height: 110px;
    transition: border-color 0.3s;
  }

  .contact-info-post:hover {
    border-color: var(--wp-accent-yellow);
  }

  .contact-info-post svg {
    width: 32px;
    height: 32px;
    color: var(--wp-accent-gold);
    flex-shrink: 0;
  }

  .info-content h4 {
    font-size: 18px;
    font-weight: 700;
    color: var(--wp-text-light);
    margin: 0;
  }

  /* Form and Map layout */
  .row-form {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 30px;
  }

  #contact-form {
    background-color: var(--wp-bg-darker);
    border: 1px solid #3d3d3d;
    padding: 40px;
  }

  #contact-form h4 {
    font-size: 20px;
    font-weight: 700;
    color: var(--wp-text-light);
    margin-bottom: 30px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .row-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 25px;
  }

  .input-line {
    position: relative;
    margin-bottom: 20px;
  }

  .input-line label {
    position: absolute;
    left: 20px;
    top: 50%;
    transform: translateY(-50%);
    color: rgba(255, 255, 255, 0.4);
    font-size: 14px;
    pointer-events: none;
  }

  .input-line input {
    width: 100%;
    background-color: transparent;
    border: 1px solid #4c4c4c;
    color: var(--wp-text-light);
    padding: 15px 15px 15px 50px;
    font-size: 14px;
    font-family: "Montserrat", sans-serif;
    outline: none;
    transition: border-color 0.3s;
  }

  .input-line input:focus,
  .input-line textarea:focus {
    border-color: var(--wp-accent-gold);
  }

  .input-line.text-area-line {
    margin-bottom: 20px;
  }

  .input-line textarea {
    width: 100%;
    height: 135px;
    background-color: transparent;
    border: 1px solid #4c4c4c;
    color: var(--wp-text-light);
    padding: 15px;
    font-size: 14px;
    font-family: "Montserrat", sans-serif;
    outline: none;
    resize: none;
    transition: border-color 0.3s;
  }

  .wpcf7-submit {
    width: 100%;
    background-color: var(--wp-accent-yellow);
    border: none;
    color: #ffffff;
    font-weight: 700;
    font-size: 14px;
    padding: 15px;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    font-family: "Montserrat", sans-serif;
    transition: background-color 0.2s;
  }

  .wpcf7-submit:hover {
    background-color: #ffffff;
    color: #000000;
  }

  /* Map Container */
  #map {
    height: 100%;
    min-height: 350px;
    border: 1px solid #3d3d3d;
  }

  .elementor-custom-embed {
    width: 100%;
    height: 100%;
  }

  .elementor-custom-embed iframe {
    width: 100%;
    height: 100%;
    min-height: 350px;
    display: block;
    filter: grayscale(1) invert(0.9) contrast(1.2); /* elegant dark map styling */
  }

  /* Cierre Banner */
  .wp-cierre-banner {
    width: 100%;
  }

  .wp-cierre-banner-img {
    width: 100%;
    height: auto;
    display: block;
  }



  /* Responsive Design */
  @media (max-width: 1023px) {
    .row-info {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .row-form {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    #map {
      height: 350px;
    }
  }

  @media (max-width: 767px) {
    .wp-page-banner {
      padding: 140px 0 60px;
    }

    .wp-banner-svg-title {
      max-width: 300px;
    }

    .row-fields {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .wpcf7-submit {
      margin-top: 10px;
    }
  }
</style>
