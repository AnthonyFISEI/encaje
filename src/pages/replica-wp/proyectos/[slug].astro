---
import LayoutWpReplica from '../../../layouts/LayoutWpReplica.astro';

const base = import.meta.env.BASE_URL === '/' ? '/' : `${import.meta.env.BASE_URL}/`;
export async function getStaticPaths() {
  const BACKEND_URL = import.meta.env.WORDPRESS_API_URL || "http://encaje-wp.test";
  const fallbackProjects = [
    {
      title: { rendered: "Residencia JCJ" },
      slug: "residencia-jcj",
      content: { rendered: "<p>Un diseño residencial único que destaca por su elegancia y espacialidad...</p>" },
      _embedded: {
        "wp:featuredmedia": [{ source_url: "https://encaje.ec/wp-content/uploads/2025/02/02_RESIDENCIAJCJ_PROYECTOS_5-1.jpg" }]
      }
    },
    {
      title: { rendered: "Playa Jama" },
      slug: "playa-jama",
      content: { rendered: "<p>Un exclusivo proyecto junto al mar pensado para disfrutar del descanso y el clima tropical...</p>" },
      _embedded: {
        "wp:featuredmedia": [{ source_url: "https://encaje.ec/wp-content/uploads/2025/02/02_PLAYAJAMA_PROYECTOS_2-1-1.jpg" }]
      }
    },
    {
      title: { rendered: "Casa DB" },
      slug: "casadb",
      content: { rendered: "<p>Una hermosa residencia familiar que se integra armónicamente con la naturaleza...</p>" },
      _embedded: {
        "wp:featuredmedia": [{ source_url: "https://encaje.ec/wp-content/uploads/2025/02/02_CASADB_PROYECTOS_6-1.jpg" }]
      }
    },
    {
      title: { rendered: "Edificio T5" },
      slug: "edificio-t5",
      content: { rendered: "<p>Un moderno edificio de departamentos diseñado para el confort urbano...</p>" },
      _embedded: {
        "wp:featuredmedia": [{ source_url: "https://encaje.ec/wp-content/uploads/2025/02/02_EDIFICIOT5_PROYECTOS_4-1.jpg" }]
      }
    },
    {
      title: { rendered: "Mama Miche" },
      slug: "mama-miche",
      content: { rendered: "<p>Un innovador espacio comercial con identidad y diseño minimalista...</p>" },
      _embedded: {
        "wp:featuredmedia": [{ source_url: "https://encaje.ec/wp-content/uploads/2025/02/02_MM_PROYECTOS_1.jpg" }]
      }
    }
  ];

  try {
    const response = await fetch(`${BACKEND_URL}/wp-json/wp/v2/projects?_embed`);
    if (!response.ok) {
      console.warn("WordPress projects API failed. Using fallback static paths.");
      return fallbackProjects.map((project) => ({
        params: { slug: project.slug },
        props: { project },
      }));
    }
    const projects = await response.json();
    return projects.map((project) => ({
      params: { slug: project.slug },
      props: { project },
    }));
  } catch (e) {
    console.warn("WordPress projects API failed. Using fallback static paths.");
    return fallbackProjects.map((project) => ({
      params: { slug: project.slug },
      props: { project },
    }));
  }
}

const { project } = Astro.props;

if (!project) {
  return Astro.redirect(`${base}replica-wp/proyectos`);
}

const media = project._embedded?.['wp:featuredmedia']?.[0];
const imageUrl = media?.source_url || '/placeholder.jpg';

// Clean shortcodes
let processedContent = project.content.rendered.replace(/\[\/?[^\]]+\]/g, '');

const hasStructuredData = (project.acf && (project.acf.estilo || project.acf.tipo_obra || project.acf.ubicacion || project.acf.cliente || project.acf.descripcion)) || 
  (project.planimetria_ambientada_gallery && project.planimetria_ambientada_gallery.length > 0) || 
  (project.planimetria_arquitectonica_gallery && project.planimetria_arquitectonica_gallery.length > 0) || 
  (project.volumetria_gallery && project.volumetria_gallery.length > 0) || 
  (project.resultados_gallery && project.resultados_gallery.length > 0) ||
  (project.renders_gallery && project.renders_gallery.length > 0) || 
  (project.planos_gallery && project.planos_gallery.length > 0);

if (hasStructuredData) {
  // If we have structured data, strip out any legacy lists, images, figures, and gallery headings from the description
  processedContent = processedContent
    .replace(/<img[^>]*>/gi, '') // Remove all image tags
    .replace(/<figure[^>]*>[\s\S]*?<\/figure>/gi, '') // Remove all figures (like Gutenberg or Elementor galleries/images)
    .replace(/<ul[^>]*>[\s\S]*?<\/ul>/gi, '') // Remove any lists (like Ficha Técnica list)
    .replace(/<h[1-6][^>]*>[\s\S]*?<\/h[1-6]>/gi, (match) => {
      // Remove headings that match typical Elementor gallery/spec section names
      const rawText = match.replace(/<[^>]*>/g, '').trim().toLowerCase();
      const text = rawText.normalize("NFD").replace(/[\u0300-\u036f]/g, "");
      if (
        text.includes('ficha') || 
        text.includes('render') || 
        text.includes('plano') || 
        text.includes('planimetri') || 
        text.includes('resultado') || 
        text.includes('proyecto')
      ) {
        return '';
      }
      return match;
    });
} else {
  // Convert the dynamic list structure from WordPress to the original theme's spans markup
  // Match: <li>\n\t\t\t\t\t\t\t\t\t\tEstilo\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\tIndustrial\t\t\t\t\t\t\t\t\t\t\n\t\t\t\t\t\t\t\t\t\t</li>
  // Regex matches any label word, newlines/spaces, and the value string inside <li> tags
  processedContent = processedContent.replace(
    /<li>\s*([A-Za-zÀ-ÿ]+)\s*\n\s*([A-Za-zÀ-ÿ0-9\s,\-\/]+)\s*<\/li>/gi,
    '<li><span class="data-name">$1</span><span class="data-val">$2</span></li>'
  );

  // We also wrap the <ul> under Ficha Técnica with the class .project-data-list
  processedContent = processedContent.replace(
    /<h2>Ficha Técnica<\/h2>\s*<ul>/gi,
    '<h2>Ficha Técnica</h2><ul class="project-data-list">'
  );
}

// Extract Yoast SEO fields if available, otherwise use defaults
const seoTitle = project.yoast_head_json?.title || `${project.title.rendered} - Encaje (Réplica WordPress)`;
const seoDescription = project.yoast_head_json?.description || project.yoast_head_json?.og_description || `Conoce los detalles de la obra ${project.title.rendered} en la réplica WordPress de Encaje.`;
const seoImage = project.yoast_head_json?.og_image?.[0]?.url || imageUrl;
---

<LayoutWpReplica title={seoTitle} description={seoDescription} image={seoImage}>
  <main class="wp-replica-detail">
    <!-- Banner Section -->
    <section class="wp-single-banner">
      <div class="wp-banner-container">
        <h1 set:html={project.title.rendered}></h1>
        <p>Solución Constructiva</p>
      </div>
    </section>

    <!-- Main Content Section -->
    <section class="wp-single-project-section">
      <div class="wp-container">
        <div class="wp-project-grid">
          <!-- Featured Image -->
          <div class="wp-project-image-box">
            <div class="wp-feature-image">
              <img src={imageUrl} alt={project.title.rendered} />
            </div>
          </div>

          <!-- Description and Specs -->
          <div class="wp-project-content-box">
            {((project.acf && (project.acf.estilo || project.acf.tipo_obra || project.acf.ubicacion || project.acf.cliente)) || 
              (project.renders_gallery && project.renders_gallery.length > 0) || 
              (project.planos_gallery && project.planos_gallery.length > 0) || 
              (project.resultados_gallery && project.resultados_gallery.length > 0)) ? (
              
              <article class="wp-project-content">
                <h2>Ficha Técnica</h2>
                <ul class="project-data-list">
                  {project.acf?.estilo && (
                    <li>
                      <span class="data-name">Estilo</span>
                      <span class="data-val">{project.acf.estilo}</span>
                    </li>
                  )}
                  {project.acf?.tipo_obra && (
                    <li>
                      <span class="data-name">Tipo</span>
                      <span class="data-val">{project.acf.tipo_obra}</span>
                    </li>
                  )}
                  {project.acf?.ubicacion && (
                    <li>
                      <span class="data-name">Ubicación</span>
                      <span class="data-val">{project.acf.ubicacion}</span>
                    </li>
                  )}
                  {project.acf?.cliente && (
                    <li>
                      <span class="data-name">Cliente</span>
                      <span class="data-val">{project.acf.cliente}</span>
                    </li>
                  )}
                </ul>

                <h2>El Proyecto</h2>
                <div class="wp-project-desc" set:html={project.acf?.descripcion ? project.acf.descripcion : processedContent} />
              </article>
            ) : (
              <article class="wp-project-content" set:html={processedContent}>
              </article>
            )}
          </div>
        </div>

        {/* Galleries rendered outside the 2-column grid for full width */}
        {((project.planimetria_ambientada_gallery && project.planimetria_ambientada_gallery.length > 0) || 
          (project.planimetria_arquitectonica_gallery && project.planimetria_arquitectonica_gallery.length > 0) || 
          (project.volumetria_gallery && project.volumetria_gallery.length > 0) || 
          (project.resultados_gallery && project.resultados_gallery.length > 0) ||
          (project.renders_gallery && project.renders_gallery.length > 0) || 
          (project.planos_gallery && project.planos_gallery.length > 0)) && (
          <div class="wp-project-galleries">
            {project.renders_gallery && project.renders_gallery.length > 0 && (
              <div class="wp-gallery-block">
                <h2>Renders</h2>
                <div class="wp-gallery-grid">
                  {project.renders_gallery.map((img) => (
                    <div class="wp-gallery-item">
                      <a href={img.url} target="_blank" rel="noopener noreferrer">
                        <img src={img.url} alt={img.alt || "Render"} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.planimetria_ambientada_gallery && project.planimetria_ambientada_gallery.length > 0 && (
              <div class="wp-gallery-block">
                <h2>Planimetría Ambientada</h2>
                <div class="wp-gallery-grid">
                  {project.planimetria_ambientada_gallery.map((img) => (
                    <div class="wp-gallery-item">
                      <a href={img.url} target="_blank" rel="noopener noreferrer">
                        <img src={img.url} alt={img.alt || "Planimetría Ambientada"} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.planimetria_arquitectonica_gallery && project.planimetria_arquitectonica_gallery.length > 0 && (
              <div class="wp-gallery-block">
                <h2>Planimetría Arquitectónica</h2>
                <div class="wp-gallery-grid">
                  {project.planimetria_arquitectonica_gallery.map((img) => (
                    <div class="wp-gallery-item">
                      <a href={img.url} target="_blank" rel="noopener noreferrer">
                        <img src={img.url} alt={img.alt || "Planimetría Arquitectónica"} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.volumetria_gallery && project.volumetria_gallery.length > 0 && (
              <div class="wp-gallery-block">
                <h2>Volumetría</h2>
                <div class="wp-gallery-grid">
                  {project.volumetria_gallery.map((img) => (
                    <div class="wp-gallery-item">
                      <a href={img.url} target="_blank" rel="noopener noreferrer">
                        <img src={img.url} alt={img.alt || "Volumetría"} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {project.resultados_gallery && project.resultados_gallery.length > 0 && (
              <div class="wp-gallery-block">
                <h2>Resultados (Obra Terminada)</h2>
                <div class="wp-gallery-grid">
                  {project.resultados_gallery.map((img) => (
                    <div class="wp-gallery-item">
                      <a href={img.url} target="_blank" rel="noopener noreferrer">
                        <img src={img.url} alt={img.alt || "Resultado"} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {/* Backwards compatibility fallback for planos */}
            {(!project.planimetria_ambientada_gallery || project.planimetria_ambientada_gallery.length === 0) && 
             (!project.planimetria_arquitectonica_gallery || project.planimetria_arquitectonica_gallery.length === 0) && 
             project.planos_gallery && project.planos_gallery.length > 0 && (
              <div class="wp-gallery-block">
                <h2>Planos</h2>
                <div class="wp-gallery-grid">
                  {project.planos_gallery.map((img) => (
                    <div class="wp-gallery-item">
                      <a href={img.url} target="_blank" rel="noopener noreferrer">
                        <img src={img.url} alt={img.alt || "Plano"} />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}
      </div>
    </section>
  </main>

  <!-- Lightbox Modal -->
  <div id="lightbox-modal" class="lightbox-modal" aria-hidden="true">
    <span class="lightbox-close">&times;</span>
    <img class="lightbox-content" id="lightbox-img" alt="Lightbox gallery preview" />
    <div id="lightbox-caption" class="lightbox-caption"></div>
  </div>
</LayoutWpReplica>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('lightbox-modal');
    const modalImg = document.getElementById('lightbox-img') as HTMLImageElement;
    const captionText = document.getElementById('lightbox-caption');
    const closeBtn = document.querySelector('.lightbox-close');

    if (modal && modalImg) {
      const galleryLinks = document.querySelectorAll('.gallery-link, .wp-gallery-item a');
      
      galleryLinks.forEach(link => {
        link.addEventListener('click', (e) => {
          e.preventDefault();
          const img = link.querySelector('img');
          const fullUrl = link.getAttribute('href');
          if (img && fullUrl) {
            modal.style.display = 'flex';
            // Force reflow
            modal.offsetHeight;
            modal.classList.add('show');
            modalImg.src = fullUrl;
            if (captionText) {
              captionText.textContent = img.getAttribute('alt') || '';
            }
          }
        });
      });

      const closeModal = () => {
        modal.classList.remove('show');
        setTimeout(() => {
          modal.style.display = 'none';
          modalImg.src = '';
        }, 300);
      };

      closeBtn?.addEventListener('click', closeModal);
      modal.addEventListener('click', (e) => {
        if (e.target === modal || e.target === closeBtn) {
          closeModal();
        }
      });
      
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.classList.contains('show')) {
          closeModal();
        }
      });
    }
  });
</script>

<style>
  .wp-replica-detail {
    background-color: var(--wp-bg-dark);
    padding-bottom: 80px;
  }

  /* Single banner */
  .wp-single-banner {
    padding: 120px 0 80px;
    background-color: var(--wp-bg-darker);
    border-bottom: 1px solid #3d3d3d;
    margin-bottom: 60px;
  }

  .wp-banner-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .wp-single-banner h1 {
    font-size: 40px;
    font-weight: 700;
    color: var(--wp-text-light);
    font-family: "Montserrat", sans-serif;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .wp-single-banner p {
    font-size: 16px;
    color: var(--wp-accent-gold);
    font-family: "Montserrat", sans-serif;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* Layout container split */
  .wp-single-project-section {
    padding: 0 0 40px 0;
  }

  .wp-container {
    max-width: 1170px;
    margin: 0 auto;
    padding: 0 30px;
  }

  .wp-project-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  @media (max-width: 1023px) {
    .wp-project-grid {
      grid-template-columns: 1fr;
    }
  }

  .wp-feature-image img {
    width: 100%;
    height: auto;
    display: block;
    border: 1px solid #3d3d3d;
  }

  /* Rendered Content styles matching WordPress */
  .wp-project-content {
    font-family: "Montserrat", sans-serif;
    text-align: justify;
  }

  .wp-project-desc {
    text-align: justify;
    white-space: pre-line;
  }

  .wp-project-desc :global(p) {
    text-align: justify;
    white-space: pre-line;
  }

  .wp-project-content h2,
  .wp-project-content :global(h2) {
    font-size: 25px;
    font-weight: 600;
    color: var(--wp-text-light);
    margin-bottom: 25px;
    margin-top: 35px;
    font-family: "Montserrat", sans-serif;
  }

  .wp-project-content h2:first-child {
    margin-top: 0;
  }

  .wp-project-content :global(p) {
    font-size: 15px;
    color: var(--wp-text-muted);
    line-height: 26px;
    margin-bottom: 20px;
    text-align: justify;
    white-space: pre-line;
  }

  /* Ficha técnica custom list styles matching Royarch style.css */
  .wp-project-content ul.project-data-list,
  .wp-project-content :global(ul.project-data-list) {
    list-style: none;
    padding: 0;
    margin: 0 0 30px;
  }

  .wp-project-content ul.project-data-list li,
  .wp-project-content :global(ul.project-data-list li) {
    display: flex;
    border: 1px solid #3d3d3d;
    border-bottom: none;
    align-items: center;
  }

  .wp-project-content ul.project-data-list li:last-child,
  .wp-project-content :global(ul.project-data-list li:last-child) {
    border-bottom: 1px solid #3d3d3d;
  }

  .wp-project-content ul.project-data-list li span,
  .wp-project-content :global(ul.project-data-list li span) {
    display: inline-block;
    color: #ffffff;
    font-size: 15px;
    font-weight: 300;
    line-height: 50px;
  }

  .wp-project-content ul.project-data-list li span.data-name,
  .wp-project-content :global(ul.project-data-list li span.data-name) {
    width: 150px;
    font-weight: 700;
    text-transform: uppercase;
    background-color: #3d3d3d;
    padding: 0 30px;
    margin-right: 15px;
    flex-shrink: 0;
  }

  .wp-project-content ul.project-data-list li span.data-val,
  .wp-project-content :global(ul.project-data-list li span.data-val) {
    padding: 0 15px;
  }

  /* WP Galleries styling */
  .wp-project-galleries {
    margin-top: 50px;
    border-top: 1px solid #3d3d3d;
    padding-top: 30px;
  }
  .wp-gallery-block {
    margin-top: 40px;
  }
  .wp-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }
  .wp-gallery-item {
    border: 1px solid #3d3d3d;
    background: var(--wp-bg-darker);
    padding: 8px;
    transition: border-color 0.2s;
  }
  .wp-gallery-item:hover {
    border-color: var(--wp-accent-yellow);
  }
  .wp-gallery-item img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  /* Lightbox Modal */
  .lightbox-modal {
    display: none;
    position: fixed;
    z-index: 99999;
    padding-top: 60px;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    overflow: auto;
    background-color: rgba(0,0,0,0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .lightbox-modal.show {
    opacity: 1;
  }
  .lightbox-content {
    margin: auto;
    display: block;
    max-width: 90%;
    max-height: 80vh;
    object-fit: contain;
    transform: scale(0.95);
    transition: transform 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 10px 40px rgba(0,0,0,0.8);
  }
  .lightbox-modal.show .lightbox-content {
    transform: scale(1);
  }
  .lightbox-close {
    position: absolute;
    top: 30px;
    right: 40px;
    color: #fff;
    font-size: 40px;
    font-weight: 300;
    cursor: pointer;
    transition: 0.3s;
  }
  .lightbox-close:hover {
    color: var(--wp-accent-yellow);
  }
  .lightbox-caption {
    position: absolute;
    bottom: 30px;
    width: 100%;
    text-align: center;
    color: #ccc;
    font-size: 14px;
    letter-spacing: 1px;
    font-family: "Montserrat", sans-serif;
  }
</style>
