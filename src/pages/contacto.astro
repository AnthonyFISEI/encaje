---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main class="contacto-page">
    <!-- Hero Section -->
    <section class="contacto-hero" style="background-image: linear-gradient(to bottom, rgba(36, 36, 36, 0.4) 0%, rgba(36, 36, 36, 0.85) 100%), url('https://encaje.ec/wp-content/uploads/2025/02/BANNER_CONTACTO.jpg');">
      <div class="hero-content">
        <span class="hero-tagline">HABLEMOS</span>
        <h1>Contacto</h1>
        <ul class="breadcrumbs">
          <li><a href="/">Inicio</a></li>
          <li class="separator">/</li>
          <li class="active">Contacto</li>
        </ul>
      </div>
    </section>

    <!-- Contact Info Cards & Grid Section -->
    <section class="contacto-section">
      <div class="section-container">
        <!-- Info Cards Grid -->
        <div class="info-cards-grid">
          <!-- WhatsApp Card -->
          <div class="info-card">
            <div class="info-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="info-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.824-1.802-5.14-4.117-6.94-6.94l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
              </svg>
            </div>
            <h3>WhatsApp</h3>
            <a href="https://wa.me/593983116325" target="_blank" rel="noopener noreferrer" class="info-link">
              +593 98 311 6325
            </a>
            <p>Atención directa e inmediata para consultas comerciales.</p>
          </div>

          <!-- Email Card -->
          <div class="info-card">
            <div class="info-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="info-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
            </div>
            <h3>Email</h3>
            <a href="mailto:info@encaje.ec" class="info-link">
              info@encaje.ec
            </a>
            <p>Escríbenos para propuestas formales, licitaciones y consultoría.</p>
          </div>

          <!-- Location Card -->
          <div class="info-card">
            <div class="info-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="info-icon">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25g9 3a9 9 0 0 1 18 0Z" />
              </svg>
            </div>
            <h3>Ubicaciones</h3>
            <span class="info-text">Quito y Salinas</span>
            <p>Cobertura y ejecución de obras a nivel nacional.</p>
          </div>
        </div>

        <!-- Form and Map Box -->
        <div class="interactive-grid">
          <!-- Premium Form -->
          <div class="premium-form-box">
            <h2>Envíanos un mensaje</h2>
            <div class="gold-line"></div>
            
            <form class="contact-form" onSubmit="event.preventDefault(); alert('Mensaje enviado exitosamente. Nos pondremos en contacto a la brevedad.');">
              <div class="form-row">
                <div class="form-group">
                  <label for="name">Nombre Completo</label>
                  <input type="text" id="name" placeholder="Tu nombre" required />
                </div>
                <div class="form-group">
                  <label for="email">Correo Electrónico</label>
                  <input type="email" id="email" placeholder="nombre@correo.com" required />
                </div>
              </div>
              
              <div class="form-group">
                <label for="subject">Asunto</label>
                <input type="text" id="subject" placeholder="¿En qué te podemos ayudar?" required />
              </div>
              
              <div class="form-group">
                <label for="message">Mensaje</label>
                <textarea id="message" rows="6" placeholder="Cuéntanos sobre tu proyecto..." required></textarea>
              </div>

              <button type="submit" class="submit-btn">
                <span>Enviar Mensaje</span>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="submit-arrow">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </button>
            </form>
          </div>

          <!-- Map Box -->
          <div class="premium-map-box">
            <iframe frameborder="0" scrolling="no" marginheight="0" marginwidth="0" src="https://maps.google.com/maps?q=Quito%2C+Ecuador&t=m&z=14&output=embed&iwloc=near" class="dark-iframe-map"></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- Parallax Closing Banner -->
    <section class="closing-banner" style="background-image: linear-gradient(to top, rgba(36,36,36,0.95), rgba(36,36,36,0.35)), url('https://encaje.ec/wp-content/uploads/2025/02/CIERRE_BANNER_CONTACTO.jpg');">
      <div class="closing-content">
        <h2>Construyamos Juntos</h2>
        <p>Proyectamos soluciones constructivas eficientes desde la responsabilidad social.</p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .contacto-page {
    background-color: var(--bg-dark);
  }

  /* Hero Styling */
  .contacto-hero {
    position: relative;
    padding: 12rem 2rem 8rem;
    text-align: center;
    background-size: cover;
    background-position: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .contacto-hero h1 {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    background: linear-gradient(135deg, var(--text-light) 40%, rgba(241, 245, 249, 0.7) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-transform: uppercase;
  }

  /* Breadcrumbs */
  .breadcrumbs {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(27, 27, 27, 0.6);
    padding: 0.5rem 1.5rem;
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-size: 0.9rem;
  }

  .breadcrumbs a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-family: var(--font-heading);
    font-weight: 500;
    transition: var(--transition-smooth);
  }

  .breadcrumbs a:hover {
    color: var(--primary);
  }

  .breadcrumbs .separator {
    color: rgba(255, 255, 255, 0.25);
  }

  .breadcrumbs .active {
    color: var(--primary);
    font-weight: 600;
    font-family: var(--font-heading);
  }

  /* Section Layout */
  .contacto-section {
    padding: 6rem 2rem;
  }

  .section-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Info Cards Grid */
  .info-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 5rem;
  }

  .info-card {
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    text-align: center;
    transition: var(--transition-smooth);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .info-card:hover {
    transform: translateY(-5px);
    border-color: var(--border-card-hover);
    box-shadow: 0 15px 35px rgba(212, 175, 55, 0.05);
  }

  .info-icon-box {
    width: 60px;
    height: 60px;
    background: rgba(212, 175, 55, 0.1);
    border: 1px solid rgba(212, 175, 55, 0.25);
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 1.5rem;
    color: var(--primary);
    transition: var(--transition-smooth);
  }

  .info-card:hover .info-icon-box {
    background: var(--primary);
    color: var(--bg-dark);
    box-shadow: 0 0 15px rgba(212, 175, 55, 0.4);
    transform: scale(1.05);
  }

  .info-icon {
    width: 1.8rem;
    height: 1.8rem;
  }

  .info-card h3 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--text-light);
  }

  .info-link,
  .info-text {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: var(--transition-smooth);
  }

  .info-link:hover {
    color: var(--primary-hover);
  }

  .info-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
    font-weight: 300;
    margin: 0;
  }

  /* Interactive Form and Map Grid */
  .interactive-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
  }

  .premium-form-box {
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: 20px;
    padding: 3rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .premium-form-box h2 {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 800;
    color: var(--text-light);
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .gold-line {
    width: 50px;
    height: 4px;
    background: linear-gradient(90deg, var(--primary), var(--secondary));
    margin-bottom: 2.5rem;
    border-radius: 2px;
  }

  /* Form Elements */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.05em;
  }

  .form-group input,
  .form-group textarea {
    background: rgba(30, 30, 30, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    color: var(--text-light);
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: var(--transition-smooth);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--primary);
    background: rgba(30, 30, 30, 0.7);
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.1);
  }

  .form-group textarea {
    resize: none;
  }

  /* Submit Button */
  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: var(--primary);
    color: var(--bg-dark);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
    border: none;
    padding: 1.1rem;
    border-radius: 30px;
    cursor: pointer;
    box-shadow: 0 10px 25px rgba(212, 175, 55, 0.2);
    transition: var(--transition-smooth);
    margin-top: 1rem;
  }

  .submit-btn:hover {
    background: var(--primary-hover);
    transform: translateY(-2px);
    box-shadow: 0 15px 35px rgba(212, 175, 55, 0.4);
  }

  .submit-arrow {
    width: 1.2rem;
    height: 1.2rem;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .submit-btn:hover .submit-arrow {
    transform: translateX(6px);
  }

  /* Premium Map Container */
  .premium-map-box {
    border: 1px solid var(--border-card);
    border-radius: 20px;
    overflow: hidden;
    height: 100%;
    min-height: 450px;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.3);
  }

  .dark-iframe-map {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
    filter: grayscale(1) invert(0.9) contrast(1.2); /* elegant premium dark map styling */
  }

  /* Closing Banner */
  .closing-banner {
    position: relative;
    padding: 10rem 2rem;
    text-align: center;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .closing-content {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .closing-content h2 {
    font-family: var(--font-heading);
    font-size: 3.2rem;
    font-weight: 800;
    color: var(--text-light);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  .closing-content p {
    color: var(--text-muted);
    font-size: 1.25rem;
    font-weight: 300;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .info-cards-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .interactive-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .premium-map-box {
      min-height: 350px;
    }
  }

  @media (max-width: 768px) {
    .contacto-hero h1 {
      font-size: 3rem;
    }

    .closing-content h2 {
      font-size: 2.2rem;
    }

    .form-row {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .premium-form-box {
      padding: 2rem;
    }
  }
</style>
